---
import TechParticles from '../components/TechParticles.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Professional IoT, Smart Home & IT Solutions in Denver | Mile High Tech Rescue",
  image = "/og-image.jpg"
} = Astro.props;

const canonicalUrl = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Canonical URL -->
  <link rel="canonical" href={`https://milehightechrescue.com${canonicalUrl}`} />
  
  <!-- Title -->
  <title>{title} | Mile High Tech Rescue</title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Brand Icons CDN (Simple Icons) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/simple-icons-font/font/simple-icons.min.css">
  
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://milehightechrescue.com${canonicalUrl}`} />
  <meta property="og:title" content={`${title} | Mile High Tech Rescue`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://milehightechrescue.com${image}`} />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={`https://milehightechrescue.com${canonicalUrl}`} />
  <meta property="twitter:title" content={`${title} | Mile High Tech Rescue`} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={`https://milehightechrescue.com${image}`} />
  
  <!-- Local Business Structured Data -->
  <script type="application/ld+json">
    {`
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Mile High Tech Rescue",
        "description": "Professional IoT, Smart Home and IT solutions in Denver, Colorado. We specialize in smart home setup, IoT integration, network security, and business automation.",
        "url": "https://milehightechrescue.com",
        "telephone": "+1-216-543-2060",
        "email": "ksavage5280@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Littleton",
          "addressRegion": "CO",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "39.6133",
          "longitude": "-105.0166"
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday"],
            "opens": "09:00",
            "closes": "19:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Friday",
            "opens": "09:00",
            "closes": "19:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Saturday",
            "opens": "10:00",
            "closes": "17:00"
          }
        ],
        "priceRange": "$$",
        "areaServed": {
          "@type": "City",
          "name": "Denver Metro Area"
        },
        "serviceType": [
          "Smart Home Installation",
          "IoT Integration",
          "Network Security",
          "IT Support",
          "Home Automation",
          "Business Technology Solutions"
        ]
      }
    `}
  </script>
  
  <!-- Service Area Structured Data -->
  <script type="application/ld+json">
    {`
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "serviceType": "Smart Home and Business Technology Solutions",
        "provider": {
          "@type": "LocalBusiness",
          "name": "Mile High Tech Rescue"
        },
        "areaServed": [
          {
            "@type": "City",
            "name": "Denver"
          },
          {
            "@type": "City",
            "name": "Littleton"
          },
          {
            "@type": "City",
            "name": "Highlands Ranch"
          },
          {
            "@type": "City",
            "name": "Lone Tree"
          },
          {
            "@type": "City",
            "name": "Centennial"
          }
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Technology Services",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Smart Home Setup"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "IoT Integration"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Network Security"
              }
            }
          ]
        }
      }
    `}
  </script>
  
</head>
<body class="bg-tech-dark text-white antialiased">
  <!-- Skip to content for accessibility -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-tech-accent text-white px-4 py-2 rounded z-50">
    Skip to main content
  </a>
  
  <!-- Navigation - Premium Glassmorphism Design -->
  <nav id="mainNav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-out" role="navigation" aria-label="Main navigation">
    <!-- Glassmorphism Background Layer -->
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-xl border-b border-white/5 transition-all duration-500" id="navBg"></div>
    
    <!-- Gradient Glow Effect (subtle) -->
    <div class="absolute inset-0 bg-gradient-to-r from-blue-500/5 via-transparent to-cyan-500/5 opacity-0 transition-opacity duration-500" id="navGlow"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-20">
        
        <!-- Logo - Enhanced with hover effect -->
        <a href="/" class="group flex items-center space-x-3" aria-label="Mile High Tech Rescue - Home">
          <div class="relative">
            <!-- Logo glow on hover -->
            <div class="absolute inset-0 bg-gradient-to-br from-blue-500 to-cyan-500 rounded-xl blur-lg opacity-0 group-hover:opacity-60 transition-opacity duration-300"></div>
            <div class="relative w-10 h-10 bg-gradient-to-br from-blue-500 to-cyan-500 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/20 group-hover:shadow-blue-500/40 transition-shadow duration-300">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
          </div>
          <div class="flex flex-col">
            <span class="font-bold text-lg tracking-tight text-white group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-white group-hover:to-cyan-300 transition-all duration-300">Mile High Tech Rescue</span>
            <span class="text-[10px] text-gray-400 uppercase tracking-widest hidden sm:block">Denver's Smart Home Experts</span>
          </div>
        </a>
        
        <!-- Desktop Navigation - Premium Links -->
        <div class="hidden lg:flex items-center space-x-1">
          <a href="/#services" class="nav-link group relative px-4 py-2 text-sm font-medium text-gray-300 hover:text-white transition-colors duration-300">
            <span class="relative z-10">Services</span>
            <span class="absolute bottom-1 left-4 right-4 h-0.5 bg-gradient-to-r from-blue-500 to-cyan-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></span>
          </a>
          <a href="/coverage" class="nav-link group relative px-4 py-2 text-sm font-medium text-gray-300 hover:text-white transition-colors duration-300">
            <span class="relative z-10">Coverage</span>
            <span class="absolute bottom-1 left-4 right-4 h-0.5 bg-gradient-to-r from-blue-500 to-cyan-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></span>
          </a>
          <a href="/solutions" class="nav-link group relative px-4 py-2 text-sm font-medium text-gray-300 hover:text-white transition-colors duration-300">
            <span class="relative z-10">Solutions</span>
            <span class="absolute bottom-1 left-4 right-4 h-0.5 bg-gradient-to-r from-blue-500 to-cyan-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></span>
          </a>
          <a href="/business" class="nav-link group relative px-4 py-2 text-sm font-medium text-gray-300 hover:text-white transition-colors duration-300">
            <span class="relative z-10">Business</span>
            <span class="absolute bottom-1 left-4 right-4 h-0.5 bg-gradient-to-r from-blue-500 to-cyan-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></span>
          </a>
          <a href="/#pricing" class="nav-link group relative px-4 py-2 text-sm font-medium text-gray-300 hover:text-white transition-colors duration-300">
            <span class="relative z-10">Pricing</span>
            <span class="absolute bottom-1 left-4 right-4 h-0.5 bg-gradient-to-r from-blue-500 to-cyan-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></span>
          </a>
          
          <!-- CTA Button - Premium Glassmorphism -->
          <a href="/#contact" class="group relative ml-4 overflow-hidden rounded-full bg-gradient-to-r from-blue-500 to-cyan-500 p-[1px] transition-all duration-300 hover:shadow-lg hover:shadow-blue-500/25 hover:scale-105">
            <span class="relative flex items-center gap-2 px-6 py-2.5 bg-slate-900 rounded-full text-sm font-semibold text-white transition-colors duration-300 group-hover:bg-transparent">
              <span>Get Help Now</span>
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </span>
          </a>
        </div>

        <!-- Mobile Menu Button - Animated Hamburger -->
        <button id="mobileMenuBtn" class="lg:hidden relative p-2 group" aria-label="Menu" aria-expanded="false">
          <div class="w-6 h-5 flex flex-col justify-between items-end">
            <span class="w-full h-0.5 bg-white transition-all duration-300 origin-right group-hover:w-4"></span>
            <span class="w-full h-0.5 bg-white transition-all duration-300"></span>
            <span class="w-3/4 h-0.5 bg-white transition-all duration-300 origin-right group-hover:w-full"></span>
          </div>
        </button>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <!-- Tech Particles Background -->
  <TechParticles />
  
  <main id="main-content" class="relative z-10">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-tech-darker border-t border-white/10 py-12" role="contentinfo">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
        <div class="col-span-1 md:col-span-2">
          <div class="flex items-center space-x-2 mb-4">
            <div class="w-8 h-8 bg-gradient-to-br from-tech-accent to-tech-cyan rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <span class="font-bold text-xl">Mile High Tech Rescue</span>
          </div>
          <p class="text-gray-400 max-w-sm">
            Denver's trusted technology partner. We rescue homes and businesses from tech troubles with expert IoT, smart home, and IT solutions.
          </p>
        </div>
        
        <div>
          <h4 class="font-semibold mb-4">Services</h4>
          <ul class="space-y-2 text-gray-400" role="list">
            <li><a href="/#services" class="hover:text-white transition-colors">Smart Home Setup</a></li>
            <li><a href="/#services" class="hover:text-white transition-colors">IoT Integration</a></li>
            <li><a href="/#services" class="hover:text-white transition-colors">Network Security</a></li>
            <li><a href="/business" class="hover:text-white transition-colors">Business Solutions</a></li>
          </ul>
        </div>
        
        <div>
          <h4 class="font-semibold mb-4">Contact</h4>
          <ul class="space-y-2 text-gray-400">
            <li>Denver Metro, Colorado</li>
            <li><a href="mailto:ksavage5280@gmail.com" class="hover:text-white transition-colors">ksavage5280@gmail.com</a></li>
            <li><a href="tel:+12165432060" class="hover:text-white transition-colors">(216) 543-2060</a></li>
          </ul>
        </div>
      </div>
      
      <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center">
        <p class="text-gray-500 text-sm">
          © 2025 Mile High Tech Rescue. All rights reserved.
        </p>
        
        <div class="flex space-x-6 mt-4 md:mt-0">
          <a href="#" class="text-gray-500 hover:text-white transition-colors text-sm">Privacy Policy</a>
          <a href="#" class="text-gray-500 hover:text-white transition-colors text-sm">Terms of Service</a>
          <a href="/sitemap-index.xml" class="text-gray-500 hover:text-white transition-colors text-sm">Sitemap</a>
        </div>
      </div>
    </div>
  </footer>
  <!-- Navbar Scroll Effect -->
  <script is:inline>
    (function() {
      const nav = document.getElementById('mainNav');
      const navBg = document.getElementById('navBg');
      const navGlow = document.getElementById('navGlow');
      
      if (!nav) return;
      
      let lastScroll = 0;
      
      window.addEventListener('scroll', function() {
        const currentScroll = window.pageYOffset;
        
        // Add solid background when scrolled
        if (currentScroll > 50) {
          navBg.classList.remove('bg-slate-900/60');
          navBg.classList.add('bg-slate-900/90');
          navGlow.classList.add('opacity-100');
        } else {
          navBg.classList.add('bg-slate-900/60');
          navBg.classList.remove('bg-slate-900/90');
          navGlow.classList.remove('opacity-100');
        }
        
        // Shrink on scroll
        if (currentScroll > 100) {
          nav.classList.add('py-0');
        } else {
          nav.classList.remove('py-0');
        }
        
        lastScroll = currentScroll;
      }, { passive: true });
    })();
  </script>

</body>
</html>
