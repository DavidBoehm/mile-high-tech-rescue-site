---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Book a Service | Mile High Tech Rescue">
  <main class="min-h-screen bg-slate-950">
    <!-- Hero -->
    <section class="relative pt-32 pb-16 bg-gradient-to-br from-slate-900 via-slate-900 to-slate-800">
      <div class="absolute inset-0 opacity-20">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-blue-500/20 via-transparent to-transparent"></div>
      </div>
      <div class="container mx-auto px-4 relative">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
            Book a <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Service</span>
          </h1>
          <p class="text-lg text-slate-400">
            Click a card below to get started
          </p>
        </div>
      </div>
    </section>

    <!-- Three Cards -->
    <section class="py-8 bg-slate-950">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <div class="grid md:grid-cols-3 gap-6">
            
            <!-- Diagnostic -->
            <a href="#diagnostic-form" 
               class="group relative bg-slate-800/50 border-2 border-slate-700 rounded-2xl p-8 hover:border-cyan-500/50 hover:shadow-xl hover:shadow-cyan-500/10 transition-all duration-300 hover:-translate-y-1 block">
              <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/5 to-blue-500/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div class="relative">
                <div class="w-14 h-14 bg-gradient-to-br from-cyan-500/20 to-blue-500/20 rounded-xl flex items-center justify-center mb-6">
                  <svg class="w-7 h-7 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-2">Book Diagnostic</h3>
                <p class="text-slate-400 text-sm mb-4">$99 flat fee. We'll diagnose any tech issue and provide a solution plan.</p>
                <div class="flex items-center text-cyan-400 text-sm font-medium">
                  <span>Get Started</span>
                  <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                  </svg>
                </div>
              </div>
            </a>

            <!-- Standard Service -->
            <a href="#standard-form" 
               class="group relative bg-slate-800/50 border-2 border-slate-700 rounded-2xl p-8 hover:border-blue-500/50 hover:shadow-xl hover:shadow-blue-500/10 transition-all duration-300 hover:-translate-y-1 block">
              <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-indigo-500/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div class="relative">
                <div class="w-14 h-14 bg-gradient-to-br from-blue-500/20 to-indigo-500/20 rounded-xl flex items-center justify-center mb-6">
                  <svg class="w-7 h-7 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-2">Standard Service</h3>
                <p class="text-slate-400 text-sm mb-4">Choose from our menu of fixed-price services. Starting at $149.</p>
                <div class="flex items-center text-blue-400 text-sm font-medium">
                  <span>Get Started</span>
                  <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                  </svg>
                </div>
              </div>
            </a>

            <!-- Custom Quote -->
            <a href="#quote-form" 
               class="group relative bg-slate-800/50 border-2 border-slate-700 rounded-2xl p-8 hover:border-purple-500/50 hover:shadow-xl hover:shadow-purple-500/10 transition-all duration-300 hover:-translate-y-1 block">
              <div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-pink-500/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div class="relative">
                <div class="w-14 h-14 bg-gradient-to-br from-purple-500/20 to-pink-500/20 rounded-xl flex items-center justify-center mb-6">
                  <svg class="w-7 h-7 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-2">Custom Quote</h3>
                <p class="text-slate-400 text-sm mb-4">Complex project? Tell us what you need and we'll provide a detailed estimate.</p>
                <div class="flex items-center text-purple-400 text-sm font-medium">
                  <span>Get Started</span>
                  <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                  </svg>
                </div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Forms Section -->
    <section class="py-16 bg-slate-950">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto space-y-12">
          
          <!-- DIAGNOSTIC FORM -->
          <div id="diagnostic-form" class="scroll-mt-24">
            <div class="bg-slate-900 border border-cyan-500/30 rounded-2xl overflow-hidden">
              <div class="bg-gradient-to-r from-cyan-500/10 to-blue-500/10 border-b border-slate-700 p-6">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-cyan-500/20 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                    </svg>
                  </div>
                  <div>
                    <h2 class="text-xl font-bold text-white">Book Diagnostic</h2>
                    <p class="text-cyan-400 text-sm">$99 flat fee • Applied to service if you proceed</p>
                  </div>
                </div>
              </div>
              
              <div class="p-6">
                <form class="booking-form space-y-5" data-type="diagnostic">
                  <input type="hidden" name="booking_type" value="diagnostic">
                  
                  <div>
                    <label class="block text-sm font-medium text-slate-300 mb-2">What needs diagnosis? *</label>
                    <select name="diagnostic_category" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-3 text-white focus:border-cyan-500 focus:outline-none transition-colors">
                      <option value="">Select category...</option>
                      <option value="smart_home">Smart Home System</option>
                      <option value="network">Network/WiFi Issues</option>
                      <option value="security">Security Camera/System</option>
                      <option value="automation">Automation Not Working</option>
                      <option value="device">Device Won't Connect</option>
                      <option value="other">Other Tech Issue</option>
                    </select>
                  </div>

                  <div>
                    <label class="block text-sm font-medium text-slate-300 mb-2">Describe the problem *</label>
                    <textarea name="diagnostic_description" rows="3" required 
                              class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-3 text-white focus:border-cyan-500 focus:outline-none transition-colors"
                              placeholder="e.g., My smart lights stopped responding to voice commands..."></textarea>
                  </div>

                  <div>
                    <label class="block text-sm font-medium text-slate-300 mb-2">How long has this been an issue?</label>
                    <select name="issue_duration" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-3 text-white focus:border-cyan-500 focus:outline-none transition-colors">
                      <option value="just_started">Just started today</option>
                      <option value="few_days">A few days</option>
                      <option value="week">About a week</option>
                      <option value="month">Over a month</option>
                      <option value="ongoing">Ongoing/intermittent</option>
                    </select>
                  </div>

                  <div class="border-t border-slate-700 pt-5">
                    <h3 class="text-sm font-medium text-slate-300 mb-4">Contact Information</h3>
                    <div class="grid md:grid-cols-2 gap-4">
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">First Name *</label>
                        <input type="text" name="first_name" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-cyan-500 focus:outline-none" placeholder="John">
                      </div>
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">Last Name *</label>
                        <input type="text" name="last_name" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-cyan-500 focus:outline-none" placeholder="Smith">
                      </div>
                    </div>
                    <div class="grid md:grid-cols-2 gap-4 mt-4">
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">Email *</label>
                        <input type="email" name="email" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-cyan-500 focus:outline-none" placeholder="john@example.com">
                      </div>
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">Phone *</label>
                        <input type="tel" name="phone" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-cyan-500 focus:outline-none" placeholder="(303) 555-0123">
                      </div>
                    </div>
                  </div>

                  <button type="submit" class="w-full bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-600 hover:to-blue-700 text-white font-bold py-4 rounded-lg transition-all">
                    Book Diagnostic - $99
                  </button>
                  
                  <div class="status-message hidden p-4 rounded-lg"></div>
                </form>
              </div>
            </div>
          </div>

          <!-- STANDARD SERVICE FORM -->
          <div id="standard-form" class="scroll-mt-24">
            <div class="bg-slate-900 border border-blue-500/30 rounded-2xl overflow-hidden">
              <div class="bg-gradient-to-r from-blue-500/10 to-indigo-500/10 border-b border-slate-700 p-6">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  </div>
                  <div>
                    <h2 class="text-xl font-bold text-white">Standard Services</h2>
                    <p class="text-blue-400 text-sm">Fixed pricing • No surprises</p>
                  </div>
                </div>
              </div>
              
              <div class="p-6">
                <form class="booking-form space-y-5" data-type="standard">
                  <input type="hidden" name="booking_type" value="standard">
                  
                  <div>
                    <label class="block text-sm font-medium text-slate-300 mb-3">Select a service *</label>
                    <div class="space-y-2">
                      <label class="flex items-center justify-between p-4 border border-slate-600 rounded-lg cursor-pointer hover:border-blue-500/50 hover:bg-blue-500/5 transition-all">
                        <div class="flex items-center">
                          <input type="radio" name="standard_service" value="wifi_setup" class="mr-3 w-4 h-4 accent-blue-500" required>
                          <span class="text-white">WiFi Network Setup</span>
                        </div>
                        <span class="text-blue-400 font-bold">$149</span>
                      </label>
                      
                      <label class="flex items-center justify-between p-4 border border-slate-600 rounded-lg cursor-pointer hover:border-blue-500/50 hover:bg-blue-500/5 transition-all">
                        <div class="flex items-center">
                          <input type="radio" name="standard_service" value="smart_thermostat" class="mr-3 w-4 h-4 accent-blue-500">
                          <span class="text-white">Smart Thermostat Install</span>
                        </div>
                        <span class="text-blue-400 font-bold">$199</span>
                      </label>
                      
                      <label class="flex items-center justify-between p-4 border border-slate-600 rounded-lg cursor-pointer hover:border-blue-500/50 hover:bg-blue-500/5 transition-all">
                        <div class="flex items-center">
                          <input type="radio" name="standard_service" value="doorbell" class="mr-3 w-4 h-4 accent-blue-500">
                          <span class="text-white">Video Doorbell Install</span>
                        </div>
                        <span class="text-blue-400 font-bold">$249</span>
                      </label>
                      
                      <label class="flex items-center justify-between p-4 border border-slate-600 rounded-lg cursor-pointer hover:border-blue-500/50 hover:bg-blue-500/5 transition-all">
                        <div class="flex items-center">
                          <input type="radio" name="standard_service" value="voice_setup" class="mr-3 w-4 h-4 accent-blue-500">
                          <span class="text-white">Voice Assistant Setup</span>
                        </div>
                        <span class="text-blue-400 font-bold">$299</span>
                      </label>
                      
                      <label class="flex items-center justify-between p-4 border border-slate-600 rounded-lg cursor-pointer hover:border-blue-500/50 hover:bg-blue-500/5 transition-all">
                        <div class="flex items-center">
                          <input type="radio" name="standard_service" value="lighting_package" class="mr-3 w-4 h-4 accent-blue-500">
                          <span class="text-white">Smart Lighting Package</span>
                        </div>
                        <span class="text-blue-400 font-bold">$449</span>
                      </label>
                      
                      <label class="flex items-center justify-between p-4 border border-slate-600 rounded-lg cursor-pointer hover:border-blue-500/50 hover:bg-blue-500/5 transition-all">
                        <div class="flex items-center">
                          <input type="radio" name="standard_service" value="camera_system" class="mr-3 w-4 h-4 accent-blue-500">
                          <span class="text-white">4-Camera Security System</span>
                        </div>
                        <span class="text-blue-400 font-bold">$599</span>
                      </label>
                      
                      <label class="flex items-center justify-between p-4 border border-slate-600 rounded-lg cursor-pointer hover:border-blue-500/50 hover:bg-blue-500/5 transition-all">
                        <div class="flex items-center">
                          <input type="radio" name="standard_service" value="home_assistant" class="mr-3 w-4 h-4 accent-blue-500">
                          <span class="text-white">Home Assistant Setup</span>
                        </div>
                        <span class="text-blue-400 font-bold">$799</span>
                      </label>
                    </div>
                  </div>

                  <div class="border-t border-slate-700 pt-5">
                    <h3 class="text-sm font-medium text-slate-300 mb-4">Contact Information</h3>
                    <div class="grid md:grid-cols-2 gap-4">
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">First Name *</label>
                        <input type="text" name="first_name" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-blue-500 focus:outline-none" placeholder="John">
                      </div>
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">Last Name *</label>
                        <input type="text" name="last_name" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-blue-500 focus:outline-none" placeholder="Smith">
                      </div>
                    </div>
                    <div class="grid md:grid-cols-2 gap-4 mt-4">
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">Email *</label>
                        <input type="email" name="email" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-blue-500 focus:outline-none" placeholder="john@example.com">
                      </div>
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">Phone *</label>
                        <input type="tel" name="phone" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-blue-500 focus:outline-none" placeholder="(303) 555-0123">
                      </div>
                    </div>
                    <div class="mt-4">
                      <label class="block text-xs text-slate-400 mb-1">Preferred Date</label>
                      <input type="date" name="preferred_date" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-blue-500 focus:outline-none">
                    </div>
                  </div>

                  <button type="submit" class="w-full bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white font-bold py-4 rounded-lg transition-all">
                    Book Service
                  </button>
                  
                  <div class="status-message hidden p-4 rounded-lg"></div>
                </form>
              </div>
            </div>
          </div>

          <!-- CUSTOM QUOTE FORM -->
          <div id="quote-form" class="scroll-mt-24">
            <div class="bg-slate-900 border border-purple-500/30 rounded-2xl overflow-hidden">
              <div class="bg-gradient-to-r from-purple-500/10 to-pink-500/10 border-b border-slate-700 p-6">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-purple-500/20 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                  </div>
                  <div>
                    <h2 class="text-xl font-bold text-white">Get Custom Quote</h2>
                    <p class="text-purple-400 text-sm">Free estimate • Response within 24 hours</p>
                  </div>
                </div>
              </div>
              
              <div class="p-6">
                <form class="booking-form space-y-5" data-type="quote">
                  <input type="hidden" name="booking_type" value="quote">
                  
                  <div>
                    <label class="block text-sm font-medium text-slate-300 mb-2">Project Type *</label>
                    <select name="project_type" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-3 text-white focus:border-purple-500 focus:outline-none transition-colors">
                      <option value="">Select project type...</option>
                      <option value="whole_home">Whole Home Smart Setup</option>
                      <option value="renovation">Home Renovation Tech</option>
                      <option value="new_construction">New Construction</option>
                      <option value="business">Business/Office</option>
                      <option value="security">Advanced Security System</option>
                      <option value="entertainment">Home Entertainment</option>
                      <option value="energy">Energy Management</option>
                      <option value="custom">Fully Custom Solution</option>
                    </select>
                  </div>

                  <div class="grid md:grid-cols-2 gap-4">
                    <div>
                      <label class="block text-sm font-medium text-slate-300 mb-2">Project Budget</label>
                      <select name="budget_range" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-3 text-white">
                        <option value="">Select budget...</option>
                        <option value="1000-3000">$1,000 - $3,000</option>
                        <option value="3000-5000">$3,000 - $5,000</option>
                        <option value="5000-10000">$5,000 - $10,000</option>
                        <option value="10000-25000">$10,000 - $25,000</option>
                        <option value="25000+">$25,000+</option>
                      </select>
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-slate-300 mb-2">Property Size</label>
                      <select name="property_size" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-3 text-white">
                        <option value="">Select size...</option>
                        <option value="apartment">Apartment/Condo</option>
                        <option value="small_home">Small Home (1-2 bed)</option>
                        <option value="medium_home">Medium Home (3-4 bed)</option>
                        <option value="large_home">Large Home (5+ bed)</option>
                        <option value="estate">Estate/Multi-building</option>
                      </select>
                    </div>
                  </div>

                  <div>
                    <label class="block text-sm font-medium text-slate-300 mb-2">Tell us about your project *</label>
                    <textarea name="project_description" rows="4" required 
                              class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-3 text-white focus:border-purple-500 focus:outline-none transition-colors"
                              placeholder="Describe what you're looking for - rooms, devices, timeline, etc."></textarea>
                  </div>

                  <div class="border-t border-slate-700 pt-5">
                    <h3 class="text-sm font-medium text-slate-300 mb-4">Contact Information</h3>
                    <div class="grid md:grid-cols-2 gap-4">
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">First Name *</label>
                        <input type="text" name="first_name" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-purple-500 focus:outline-none" placeholder="John">
                      </div>
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">Last Name *</label>
                        <input type="text" name="last_name" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-purple-500 focus:outline-none" placeholder="Smith">
                      </div>
                    </div>
                    <div class="grid md:grid-cols-2 gap-4 mt-4">
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">Email *</label>
                        <input type="email" name="email" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-purple-500 focus:outline-none" placeholder="john@example.com">
                      </div>
                      <div>
                        <label class="block text-xs text-slate-400 mb-1">Phone *</label>
                        <input type="tel" name="phone" required class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-purple-500 focus:outline-none" placeholder="(303) 555-0123">
                      </div>
                    </div>
                  </div>

                  <button type="submit" class="w-full bg-gradient-to-r from-purple-500 to-pink-600 hover:from-purple-600 hover:to-pink-700 text-white font-bold py-4 rounded-lg transition-all">
                    Get Free Quote
                  </button>
                  
                  <div class="status-message hidden p-4 rounded-lg"></div>
                </form>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>

  <script>
    // Set minimum date to today
    document.querySelectorAll('input[type="date"]').forEach(input => {
      input.min = new Date().toISOString().split('T')[0];
    });

    // Handle form submissions
    document.querySelectorAll('.booking-form').forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);
        const btn = e.target.querySelector('button[type="submit"]');
        const statusDiv = e.target.querySelector('.status-message');
        
        const originalText = btn.textContent;
        btn.disabled = true;
        btn.innerHTML = '<span class="animate-spin">⟳</span> Sending...';
        
        try {
          const response = await fetch('https://api.milehightechrescue.com/booking', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          
          if (response.ok) {
            statusDiv.className = 'block p-4 rounded-lg bg-green-500/20 border border-green-500/50 text-green-400';
            statusDiv.innerHTML = '<strong>✅ Request Received!</strong><br>We will contact you within 24 hours.';
            e.target.reset();
          } else {
            throw new Error('API error');
          }
        } catch (err) {
          statusDiv.className = 'block p-4 rounded-lg bg-yellow-500/20 border border-yellow-500/50 text-yellow-400';
          statusDiv.innerHTML = '<strong>⚠️ Request Saved</strong><br>We will contact you soon.';
        }
        
        btn.disabled = false;
        btn.textContent = originalText;
      });
    });
  </script>
</Layout>
