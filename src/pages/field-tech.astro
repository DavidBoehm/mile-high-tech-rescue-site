---
import Layout from '../layouts/Layout.astro';

// This is a mockup/prototype of what a field tech backend could look like
// In production, this would need authentication, database, API, etc.
---

<Layout title="Field Tech Portal - Login">
  <section class="pt-32 pb-24 min-h-screen bg-tech-dark">
    <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Login Card -->
      <div class="bg-tech-card border border-white/10 rounded-2xl p-8">
        <div class="text-center mb-8">
          <div class="w-16 h-16 bg-gradient-to-br from-tech-accent to-tech-cyan rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h1 class="text-2xl font-bold">Field Tech Portal</h1>
          <p class="text-gray-400 text-sm mt-2">Mile High Tech Rescue - Staff Only</p>
        </div>
        
        <form class="space-y-6" onsubmit="event.preventDefault(); alert('Demo: Authentication would happen here');">
          <div>
            <label class="block text-sm font-medium text-gray-400 mb-2">Email</label>
            <input type="email" 
                   class="w-full bg-tech-darker border border-white/10 rounded-lg px-4 py-3 text-white focus:border-tech-accent focus:outline-none transition-colors"
                   placeholder="tech@milehightechrescue.com"
                   required>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-400 mb-2">Password</label>
            <input type="password" 
                   class="w-full bg-tech-darker border border-white/10 rounded-lg px-4 py-3 text-white focus:border-tech-accent focus:outline-none transition-colors"
                   placeholder="••••••••"
                   required>
          </div>
          
          <button type="submit" 
                  class="w-full bg-tech-accent hover:bg-tech-cyan text-white font-semibold py-3 rounded-lg transition-all">
            Sign In
          </button>
        </form>
        
        <div class="mt-6 pt-6 border-t border-white/10 text-center">
          <a href="#" class="text-sm text-tech-accent hover:text-tech-cyan transition-colors">
            Forgot password?
          </a>
        </div>
      </div>
      
      <!-- Features Preview -->
      <div class="mt-12 grid grid-cols-2 gap-4">
        <div class="bg-tech-card/50 border border-white/5 rounded-xl p-4 text-center">
          <svg class="w-8 h-8 text-tech-accent mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <p class="text-sm text-gray-400">View Schedule</p>
        </div>
        
        <div class="bg-tech-card/50 border border-white/5 rounded-xl p-4 text-center">
          <svg class="w-8 h-8 text-tech-accent mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
          </svg>
          <p class="text-sm text-gray-400">Update Jobs</p>
        </div>
        
        <div class="bg-tech-card/50 border border-white/5 rounded-xl p-4 text-center">
          <svg class="w-8 h-8 text-tech-accent mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <p class="text-sm text-gray-400">Upload Photos</p>
        </div>
        
        <div class="bg-tech-card/50 border border-white/5 rounded-xl p-4 text-center">
          <svg class="w-8 h-8 text-tech-accent mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <p class="text-sm text-gray-400">Invoice & Billing</p>
        </div>
      </div>
      
    </div>
  </section>
</Layout>
