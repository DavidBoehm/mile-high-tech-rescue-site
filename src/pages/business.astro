---
import Layout from '../layouts/Layout.astro';
import BusinessSolutions from '../components/BusinessSolutions.astro';
import ContactCTA from '../components/ContactCTA.astro';

const pageDescription = "Business technology solutions in Denver that pay for themselves through energy savings, time savings, and security protection. Free ROI assessment available.";
---

<Layout 
  title="Business Technology Solutions - Energy, Time & Security Savings" 
  description={pageDescription}
  image="/business-og.jpg"
>
  <!-- Hero for Business Page -->
  <section class="pt-32 pb-16 bg-tech-dark relative overflow-hidden" aria-label="Business solutions hero">
    <div class="absolute inset-0 bg-gradient-to-br from-green-500/10 via-transparent to-blue-500/10"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center space-x-2 bg-green-500/20 border border-green-500/30 rounded-full px-4 py-2 mb-6">
          <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
          <span class="text-green-400 font-medium">Business Solutions</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          Denver <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-blue-400">Business Technology</span> That Pays for Itself
        </h1>
        
        <p class="text-xl text-gray-400 mb-8">
          Smart automation, energy management, and security solutions for Denver and Littleton businesses. <strong class="text-white">Cut costs by 10-30%</strong> while protecting your assets.
        </p>
        
        <a href="tel:+12165432060" 
           class="inline-block bg-tech-accent hover:bg-tech-cyan text-white px-8 py-4 rounded-full font-semibold text-lg transition-all hover:shadow-lg hover:shadow-tech-accent/25">
          Call for Free Savings Assessment
        </a>
      </div>
    </div>
  </section>
  
  <BusinessSolutions />
  <ContactCTA />
</Layout>