---
import Layout from '../layouts/Layout.astro';
import ContactCTA from '../components/ContactCTA.astro';

const pageDescription = "Real smart home solutions for real problems. Drought-conscious irrigation, flood protection, cord cutting, and safety monitoring. Based in Denver, serving Colorado.";
---

<Layout 
  title="Smart Home Solutions - Real Examples That Work" 
  description={pageDescription}
>
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-tech-dark relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-tech-accent/10 via-transparent to-tech-cyan/10"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center space-x-2 bg-tech-accent/20 border border-tech-accent/30 rounded-full px-4 py-2 mb-6">
          <svg class="w-5 h-5 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
          <span class="text-tech-accent font-medium">Real Solutions</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          Smart Home Solutions for <span class="text-transparent bg-clip-text bg-gradient-to-r from-tech-accent to-tech-cyan">Real Life</span>
        </h1>
        
        <p class="text-xl text-gray-400 mb-8">
          Not sure what's possible? Here are actual solutions we've built for Colorado homeowners. From water conservation to safety systems that actually work.
        </p>
      </div>
    </div>
  </section>

  <!-- Solutions Grid -->
  <section class="py-24 bg-tech-darker">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        
        <!-- Sprinkler Control -->
        <div class="bg-tech-card border border-white/10 rounded-3xl p-8 hover:border-tech-accent/50 transition-all group">
          <div class="flex items-start space-x-4 mb-6">
            <div class="w-14 h-14 bg-blue-500/20 rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg class="w-7 h-7 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold mb-2">Smart Sprinkler Control</h2>
              <p class="text-blue-400 text-sm font-medium">Water Conservation • Drought Response</p>
            </div>
          </div>
          
          <p class="text-gray-400 mb-6">
            Colorado's droughts are real. Smart irrigation systems skip watering when rain is forecast, adjust for seasonal changes, and comply with watering restrictions automatically. Cut your water bill by 20-50% while keeping your lawn alive.
          </p>
          
          <div class="space-y-3">
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Weather-based scheduling (skips rain days)</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Zone-by-zone control from your phone</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Flow monitoring (detects broken heads)</span>
            </div>
          </div>
        </div>

        <!-- Flood Protection -->
        <div class="bg-tech-card border border-white/10 rounded-3xl p-8 hover:border-tech-accent/50 transition-all group">
          <div class="flex items-start space-x-4 mb-6">
            <div class="w-14 h-14 bg-cyan-500/20 rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg class="w-7 h-7 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold mb-2">Flood Protection & Auto Shutoff</h2>
              <p class="text-cyan-400 text-sm font-medium">Water Damage Prevention • Insurance Savings</p>
            </div>
          </div>
          
          <p class="text-gray-400 mb-6">
            Water damage is one of the most expensive home disasters. Smart water monitors detect leaks instantly and automatic shutoff valves stop the flow before your basement becomes a pool. Some insurance companies offer discounts for these systems.
          </p>
          
          <div class="space-y-3">
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Leak sensors under sinks, near water heater</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Automatic main water valve shutoff</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Instant phone alerts anywhere</span>
            </div>
          </div>
        </div>

        <!-- Cord Cutting -->
        <div class="bg-tech-card border border-white/10 rounded-3xl p-8 hover:border-tech-accent/50 transition-all group">
          <div class="flex items-start space-x-4 mb-6">
            <div class="w-14 h-14 bg-red-500/20 rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold mb-2">Ultimate Cord Cutting</h2>
              <p class="text-red-400 text-sm font-medium">Entertainment • Streaming • Whole-Home Audio</p>
            </div>
          </div>
          
          <p class="text-gray-400 mb-6">
            Ditch the cable box and $200+ monthly bills. We set up streaming solutions that actually work for your family — including whole-home audio, unified remotes, and outdoor TV setups for Colorado's beautiful evenings.
          </p>
          
          <div class="space-y-3">
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>One remote controls everything (really)</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Whole-home audio (sync music everywhere)</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Outdoor TV and patio speaker setup</span>
            </div>
          </div>
        </div>

        <!-- Presence & Fall Detection -->
        <div class="bg-tech-card border border-white/10 rounded-3xl p-8 hover:border-tech-accent/50 transition-all group">
          <div class="flex items-start space-x-4 mb-6">
            <div class="w-14 h-14 bg-purple-500/20 rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg class="w-7 h-7 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold mb-2">Presence & Fall Detection</h2>
              <p class="text-purple-400 text-sm font-medium">Safety • Elderly Care • Peace of Mind</p>
            </div>
          </div>
          
          <p class="text-gray-400 mb-6">
            Smart safety systems that respect privacy. Know when elderly parents are up and about. Detect falls without cameras in bathrooms. Get alerts if no one's moved by noon. False alarms are minimized by AI that learns normal patterns.
          </p>
          
          <div class="space-y-3">
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Radar-based fall detection (no cameras)</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Daily activity check-ins for loved ones</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-300">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Emergency contact alerts with location</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Additional Solutions -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Security -->
        <div class="bg-tech-card/50 border border-white/5 rounded-2xl p-6">
          <h3 class="text-lg font-semibold mb-2 flex items-center space-x-2">
            <svg class="w-5 h-5 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            <span>Smart Security</span>
          </h3>
          <p class="text-gray-400 text-sm">Doorbell cameras, smart locks, window sensors. Know who's at the door from anywhere.</p>
        </div>

        <!-- Climate -->
        <div class="bg-tech-card/50 border border-white/5 rounded-2xl p-6">
          <h3 class="text-lg font-semibold mb-2 flex items-center space-x-2">
            <svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
            </svg>
            <span>Climate Control</span>
          </h3>
          <p class="text-gray-400 text-sm">Smart thermostats, zoned heating, automated blinds. Save 20-30% on energy bills.</p>
        </div>

        <!-- Lighting -->
        <div class="bg-tech-card/50 border border-white/5 rounded-2xl p-6">
          <h3 class="text-lg font-semibold mb-2 flex items-center space-x-2">
            <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
            <span>Smart Lighting</span>
          </h3>
          <p class="text-gray-400 text-sm">Circadian rhythm lighting, motion-activated paths, vacation mode security.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-tech-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Have a Different Challenge?
      </h2>
      <p class="text-xl text-gray-400 mb-8">
        These are just examples. If you can describe the problem, we can probably automate the solution. Let's talk about what you're trying to accomplish.
      </p>
      <a href="tel:+12165432060" class="inline-block bg-tech-accent hover:bg-tech-cyan text-white px-8 py-4 rounded-full font-semibold text-lg transition-all hover:shadow-lg hover:shadow-tech-accent/25">
        Discuss Your Project
      </a>
    </div>
  </section>

  <ContactCTA />
</Layout>
