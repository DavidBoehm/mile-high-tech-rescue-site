---
---

<section id="research" class="py-24 bg-tech-dark relative overflow-hidden">
  <!-- Background accent -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-tech-accent/5 to-transparent"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left: Content -->
      <div>
        <div class="inline-flex items-center space-x-2 bg-tech-accent/20 border border-tech-accent/30 rounded-full px-4 py-2 mb-6">
          <svg class="w-5 h-5 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
          <span class="text-tech-accent font-medium">Smart Approach</span>
        </div>
        
        <h2 class="text-4xl md:text-5xl font-bold mb-6">
          We Do the <span class="text-transparent bg-clip-text bg-gradient-to-r from-tech-accent to-tech-cyan">Research</span> For You
        </h2>
        
        <p class="text-xl text-gray-400 mb-8">
          Every smart home is different. We research, design, and implement solutions that actually fit your needs — not some generic package.
        </p>
        
        <div class="space-y-6">
          <!-- Point 1 -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-tech-accent/20 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Needs Assessment</h3>
              <p class="text-gray-400">We learn how you actually live and what problems you're trying to solve. No cookie-cutter solutions.</p>
            </div>
          </div>
          
          <!-- Point 2 -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-tech-cyan/20 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-tech-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Curated Product Selection</h3>
              <p class="text-gray-400">We only recommend reliable, well-supported devices that work together. <span class="text-white font-medium">Life's too short for random IoT garbage.</span></p>
            </div>
          </div>
          
          <!-- Point 3 -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2">Already Have Devices?</h3>
              <p class="text-gray-400">No problem. We'll work with what you've got, integrate it properly, and fill any gaps with quality hardware.</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Right: Visual -->
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-tech-accent/20 to-tech-cyan/20 rounded-3xl blur-3xl"></div>
        <div class="relative bg-tech-card border border-white/10 rounded-3xl p-8">
          <!-- Quote -->
          <div class="mb-8">
            <svg class="w-10 h-10 text-tech-accent/40 mb-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <p class="text-xl text-gray-300 italic">
              "I've been burned by cheap smart bulbs and random WiFi plugs that stopped working after a month. You saved me from buying more junk."
            </p>
          </div>
          
          <!-- Client attribution -->
          <div class="flex items-center space-x-4">
            <div class="w-12 h-12 bg-gradient-to-br from-tech-accent to-tech-cyan rounded-full flex items-center justify-center text-white font-bold">
              SM
            </div>
            <div>
              <p class="font-semibold">Sarah M.</p>
              <p class="text-sm text-gray-500">Homeowner, Highlands Ranch</p>
            </div>
          </div>
          
          <!-- Divider -->
          <div class="border-t border-white/10 my-8"></div>
          
          <!-- Our approach list -->
          <h4 class="font-semibold text-tech-accent mb-4">Our Approach:</h4>
          <ul class="space-y-3 text-gray-400">
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Research before recommending</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Quality over cheap quick fixes</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Full implementation included</span>
            </li>
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Training so you actually use it</span>
            </li>
          </ul>
        </div>
      </div>
      
    </div>
  </div>
</section>
