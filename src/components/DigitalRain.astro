---
---

<div class="absolute inset-0 overflow-hidden pointer-events-none z-0" aria-hidden="true">
  <canvas id="digitalRain" class="w-full h-full" style="filter: drop-shadow(0 0 6px rgba(59, 130, 246, 0.3));"></canvas>
</div>

<script is:inline>
  (function() {
    const canvas = document.getElementById('digitalRain');
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d');
    
    // Set canvas size - use half resolution for performance
    function resize() {
      const dpr = Math.min(window.devicePixelRatio, 1.5); // Cap at 1.5x
      canvas.width = Math.floor(canvas.offsetWidth * dpr);
      canvas.height = Math.floor(canvas.offsetHeight * dpr);
      ctx.scale(dpr, dpr);
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });
    
    // Characters to use
    const chars = '01アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホ';
    
    // Larger font = fewer columns = better performance
    const fontSize = 20;
    let columns = Math.ceil(canvas.offsetWidth / fontSize);
    const drops = [];
    
    // Splash particles - limited array
    const splashes = [];
    const MAX_SPLASHES = 10; // Limit concurrent splashes
    
    // Initialize drops
    for (let i = 0; i < columns; i++) {
      drops[i] = Math.random() * -100;
    }
    
    let frameCount = 0;
    let time = 0;
    
    // Pre-calculate colors
    function getDropHue(i) {
      return (i * 3) % 360;
    }
    
    function draw() {
      frameCount++;
      
      // Only update every 4th frame (15fps) for performance
      const shouldUpdate = frameCount % 4 === 0;
      
      // Clear with fade
      ctx.fillStyle = 'rgba(15, 23, 42, 0.15)';
      ctx.fillRect(0, 0, canvas.offsetWidth, canvas.offsetHeight);
      
      ctx.font = fontSize + 'px monospace';
      
      if (shouldUpdate) {
        time += 1;
      }
      
      // Update and draw splashes (every frame for smoothness)
      ctx.fillStyle = '#fff';
      for (let i = splashes.length - 1; i >= 0; i--) {
        const splash = splashes[i];
        splash.life--;
        
        // Very subtle splash - just 2 tiny dots
        if (splash.life > 8) {
          const alpha = (splash.life - 8) / 4 * 0.3; // Max 0.3 opacity
          ctx.fillStyle = `hsla(${splash.hue}, 80%, 60%, ${alpha})`;
          
          // Left particle
          const lx = splash.x - (12 - splash.life) * 0.8;
          const ly = splash.y - (12 - splash.life) * 0.3;
          ctx.fillRect(lx, ly, 2, 2);
          
          // Right particle  
          const rx = splash.x + (12 - splash.life) * 0.8;
          const ry = splash.y - (12 - splash.life) * 0.3;
          ctx.fillRect(rx, ry, 2, 2);
        }
        
        if (splash.life <= 0) {
          splashes.splice(i, 1);
        }
      }
      
      // Draw rain (only every other column for performance)
      for (let i = 0; i < drops.length; i += 2) {
        const char = chars[Math.floor(Math.random() * chars.length)];
        const x = i * fontSize + fontSize / 2;
        const y = drops[i] * fontSize;
        
        if (y > 0 && y < canvas.offsetHeight) {
          const hue = getDropHue(i + Math.floor(time));
          ctx.fillStyle = `hsla(${hue}, 90%, 65%, 0.7)`;
          ctx.fillText(char, x - fontSize / 2, y);
        }
        
        // Check if hit bottom
        if (shouldUpdate) {
          const nextY = (drops[i] + 1) * fontSize;
          
          // Hit bottom - create subtle splash (limited)
          if (y > canvas.offsetHeight - 30 && nextY >= canvas.offsetHeight && splashes.length < MAX_SPLASHES) {
            if (Math.random() > 0.7) { // Only 30% of drops create splashes
              splashes.push({
                x: x,
                y: canvas.offsetHeight - 2,
                hue: getDropHue(i),
                life: 12 // 0.2 seconds at 60fps
              });
            }
          }
          
          // Move drop
          drops[i]++;
          
          // Reset
          if (y > canvas.offsetHeight && Math.random() > 0.99) {
            drops[i] = 0;
          }
        }
      }
      
      requestAnimationFrame(draw);
    }
    
    draw();
  })();
</script>
