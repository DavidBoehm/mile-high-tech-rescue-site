---
---

<div class="absolute inset-0 overflow-hidden pointer-events-none z-0 opacity-0 transition-opacity duration-1000" 
     id="rainContainer"
     aria-hidden="true">
  <canvas id="digitalRain" class="w-full h-full" style="filter: drop-shadow(0 0 8px rgba(59, 130, 246, 0.5));"></canvas>
</div>

<div id="easterEggHint" class="fixed bottom-4 right-4 text-xs text-gray-600/30 hover:text-gray-500/50 transition-colors cursor-default select-none z-50">
  ?
</div>

<script is:inline>
  (function() {
    const container = document.getElementById('rainContainer');
    const canvas = document.getElementById('digitalRain');
    if (!canvas || !container) return;
    
    let isActive = false;
    let animationId = null;
    
    const ctx = canvas.getContext('2d');
    
    // Set canvas size
    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resize();
    window.addEventListener('resize', resize);
    
    // Characters to use
    const chars = '01アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン☆★♦♠♣♥';
    
    // Column setup
    const fontSize = 32;
    let columns = Math.floor(canvas.width / fontSize);
    const drops = [];
    
    // Initialize drops
    for (let i = 0; i < columns; i++) {
      drops[i] = Math.random() * -200;
    }
    
    let frameCount = 0;
    let time = 0;
    
    function draw() {
      if (!isActive) return;
      
      // Semi-transparent fade for trail effect
      ctx.fillStyle = 'rgba(15, 23, 42, 0.1)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      ctx.font = 'bold ' + fontSize + 'px monospace';
      
      // Update every 6th frame
      frameCount++;
      const shouldUpdate = frameCount % 6 === 0;
      
      if (shouldUpdate) {
        time += 0.5;
      }
      
      // Draw rain
      for (let i = 0; i < drops.length; i++) {
        const char = chars[Math.floor(Math.random() * chars.length)];
        
        const x = i * fontSize + fontSize / 2;
        const y = drops[i] * fontSize;
        
        if (y > 0 && y < canvas.height) {
          const gradient = ctx.createLinearGradient(x, y - 30, x, y);
          const hue1 = (i * 2 + time) % 360;
          const hue2 = (i * 2 + time + 30) % 360;
          
          gradient.addColorStop(0, `hsla(${hue1}, 100%, 70%, 0.3)`);
          gradient.addColorStop(1, `hsla(${hue2}, 100%, 70%, 1)`);
          
          ctx.fillStyle = gradient;
          ctx.shadowBlur = 20;
          ctx.shadowColor = `hsla(${(i * 2 + time) % 360}, 100%, 70%, 0.8)`;
          
          ctx.fillText(char, x - fontSize / 2, y);
          ctx.shadowBlur = 0;
        }
        
        if (shouldUpdate) {
          drops[i]++;
          
          if (y > canvas.height && Math.random() > 0.97) {
            drops[i] = 0;
          }
        }
      }
      
      animationId = requestAnimationFrame(draw);
    }
    
    // Konami Code: ↑ ↑ ↓ ↓ ← → ← → B A
    const konamiCode = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'b', 'a'];
    let konamiIndex = 0;
    
    document.addEventListener('keydown', (e) => {
      if (e.key === konamiCode[konamiIndex]) {
        konamiIndex++;
        if (konamiIndex === konamiCode.length) {
          // Konami code complete!
          isActive = !isActive;
          container.classList.toggle('opacity-0', !isActive);
          container.classList.toggle('opacity-100', isActive);
          
          if (isActive) {
            draw();
          } else {
            cancelAnimationFrame(animationId);
          }
          
          konamiIndex = 0;
        }
      } else {
        konamiIndex = 0;
      }
    });
    
    // Also toggle on triple-click of the hint
    document.getElementById('easterEggHint').addEventListener('click', () => {
      isActive = !isActive;
      container.classList.toggle('opacity-0', !isActive);
      container.classList.toggle('opacity-100', isActive);
      
      if (isActive) {
        draw();
      } else {
        cancelAnimationFrame(animationId);
      }
    });
  })();
</script>
