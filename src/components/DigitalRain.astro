---
---

<div class="absolute inset-0 overflow-hidden pointer-events-none z-0" aria-hidden="true">
  <canvas id="digitalRain" class="w-full h-full" style="filter: drop-shadow(0 0 8px rgba(59, 130, 246, 0.5));"></canvas>
</div>

<script is:inline>
  (function() {
    const canvas = document.getElementById('digitalRain');
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d');
    
    // Set canvas size
    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resize();
    window.addEventListener('resize', resize);
    
    // Characters to use
    const chars = '01アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン☆★♦♠♣♥';
    
    // Column setup
    const fontSize = 16;
    let columns = Math.floor(canvas.width / fontSize);
    const drops = [];
    
    // Splash particles array
    const splashes = [];
    
    // Rainbow color generator
    function getRainbowColor(position, time) {
      const hue = (position + time * 0.5) % 360;
      return `hsl(${hue}, 80%, 60%)`;
    }
    
    // Splash particle class
    class Splash {
      constructor(x, y, hue) {
        this.x = x;
        this.y = y;
        this.hue = hue;
        this.particles = [];
        this.life = 30; // frames
        
        // Create splash particles
        for (let i = 0; i < 5; i++) {
          this.particles.push({
            x: x,
            y: y,
            vx: (Math.random() - 0.5) * 4,
            vy: -Math.random() * 3 - 1,
            size: Math.random() * 3 + 1
          });
        }
      }
      
      update() {
        this.life--;
        for (let p of this.particles) {
          p.x += p.vx;
          p.y += p.vy;
          p.vy += 0.15; // gravity
        }
      }
      
      draw(ctx) {
        const alpha = this.life / 30;
        ctx.fillStyle = `hsla(${this.hue}, 100%, 70%, ${alpha})`;
        
        for (let p of this.particles) {
          ctx.shadowBlur = 10;
          ctx.shadowColor = `hsla(${this.hue}, 100%, 70%, ${alpha})`;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fill();
          ctx.shadowBlur = 0;
        }
      }
    }
    
    // Initialize drops at random heights
    for (let i = 0; i < columns; i++) {
      drops[i] = Math.random() * -200;
    }
    
    let frameCount = 0;
    let time = 0;
    
    function draw() {
      // Semi-transparent fade for trail effect
      ctx.fillStyle = 'rgba(15, 23, 42, 0.1)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      ctx.font = 'bold ' + fontSize + 'px monospace';
      
      // Slow down - only update every 3rd frame
      frameCount++;
      const shouldUpdate = frameCount % 3 === 0;
      
      if (shouldUpdate) {
        time += 0.5;
      }
      
      // Update and draw splashes
      for (let i = splashes.length - 1; i >= 0; i--) {
        splashes[i].update();
        splashes[i].draw(ctx);
        if (splashes[i].life <= 0) {
          splashes.splice(i, 1);
        }
      }
      
      // Draw rain
      for (let i = 0; i < drops.length; i++) {
        // Random character
        const char = chars[Math.floor(Math.random() * chars.length)];
        
        const x = i * fontSize + fontSize / 2;
        const y = drops[i] * fontSize;
        
        if (y > 0 && y < canvas.height) {
          // Rainbow gradient based on column position and time
          const gradient = ctx.createLinearGradient(x, y - 20, x, y);
          const hue1 = (i * 2 + time) % 360;
          const hue2 = (i * 2 + time + 30) % 360;
          
          gradient.addColorStop(0, `hsla(${hue1}, 100%, 70%, 0.3)`);
          gradient.addColorStop(1, `hsla(${hue2}, 100%, 70%, 1)`);
          
          ctx.fillStyle = gradient;
          
          // Add glow effect
          ctx.shadowBlur = 15;
          ctx.shadowColor = `hsla(${(i * 2 + time) % 360}, 100%, 70%, 0.8)`;
          
          ctx.fillText(char, x - fontSize / 2, y);
          
          // Reset shadow for next char
          ctx.shadowBlur = 0;
        }
        
        // Check if hit bottom
        if (shouldUpdate) {
          const nextY = (drops[i] + 1) * fontSize;
          
          // Hit bottom - create splash
          if (y > 0 && nextY >= canvas.height) {
            const hue = (i * 2 + time) % 360;
            splashes.push(new Splash(x, canvas.height - 5, hue));
          }
          
          // Move drop
          drops[i]++;
          
          // Slow down even more randomly
          if (Math.random() > 0.95) {
            // Skip this update (character stays)
            drops[i]--;
          }
          
          // Reset when off screen
          if (y > canvas.height && Math.random() > 0.985) {
            drops[i] = 0;
          }
        }
      }
      
      requestAnimationFrame(draw);
    }
    
    draw();
  })();
</script>
