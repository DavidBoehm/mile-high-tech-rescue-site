---
---

<section id="why-us" class="py-24 bg-tech-dark relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-tech-accent/5 to-transparent"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left: Content -->
      <div>
        <h2 class="text-4xl md:text-5xl font-bold mb-6">
          Why Choose <span class="text-tech-accent">Mile High Tech Rescue</span>?
        </h2>
        
        <p class="text-xl text-gray-400 mb-12">
          We're not just another IT company. We're your technology partners who actually show up, explain things in plain English, and fix it right the first time.
        </p>
        
        <div class="space-y-8">
          <!-- Feature 1 -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-tech-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2">Same-Day Response</h3>
              <p class="text-gray-400">Tech emergencies can't wait. We prioritize urgent issues and aim to resolve them within hours, not days.</p>
            </div>
          </div>
          
          <!-- Feature 2 -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-tech-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2">Local Denver Team</h3>
              <p class="text-gray-400">Real technicians who know Denver. No outsourcing, no calling a national hotline. Just local expertise.</p>
            </div>
          </div>
          
          <!-- Feature 3 -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-tech-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2">No Geek Speak</h3>
              <p class="text-gray-400">We explain what's wrong and what we're doing in terms you understand. Knowledge is power.</p>
            </div>
          </div>
          
          <!-- Feature 4 -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-tech-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2">Upfront Pricing</h3>
              <p class="text-gray-400">No surprises, no hidden fees. You'll know exactly what it costs before we start. Fair pricing, premium service.</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Right: Stats -->
      <div class="bg-tech-card border border-white/10 rounded-2xl p-8">
        <h3 class="text-2xl font-bold mb-8 text-center">By The Numbers</h3>
        
        <div class="grid grid-cols-2 gap-6">
          <div class="text-center p-6 bg-tech-dark rounded-xl">
            <div class="w-12 h-12 mx-auto mb-3 bg-tech-accent/20 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div class="text-lg font-bold text-white mb-1">Founder-Led</div>
            <div class="text-gray-400 text-sm">Personal Service</div>
          </div>
          
          <div class="text-center p-6 bg-tech-dark rounded-xl">
            <div class="text-4xl font-bold text-tech-accent mb-2">100%</div>
            <div class="text-gray-400">Client Satisfaction</div>
          </div>
          
          <div class="text-center p-6 bg-tech-dark rounded-xl">
            <div class="text-4xl font-bold text-tech-accent mb-2">4.9★</div>
            <div class="text-gray-400">Average Rating</div>
          </div>
          
          <div class="text-center p-6 bg-tech-dark rounded-xl">
            <div class="text-4xl font-bold text-tech-accent mb-2">24/7</div>
            <div class="text-gray-400">Emergency Support</div>
          </div>
        </div>
        
        <div class="mt-8 p-6 bg-gradient-to-r from-tech-accent/10 to-tech-cyan/10 rounded-xl border border-tech-accent/20">
            <p class="text-center text-lg italic text-gray-300">
            "Tech problems hit different at altitude. We know because we live here too."
          </p>
          <p class="text-center text-gray-400 mt-2">— Founder, Mile High Tech Rescue</p>
        </div>
      </div>
    </div>
  </div>
</section>
