---
---

<section id="contact" class="py-24 bg-gradient-to-b from-tech-dark to-tech-darker relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 bg-gradient-to-br from-tech-accent/5 via-transparent to-tech-cyan/5"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-tech-accent/10 rounded-full blur-3xl"></div>
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="bg-tech-card border border-white/10 rounded-3xl p-8 md:p-16 text-center">
      
      <div class="w-20 h-20 bg-gradient-to-br from-tech-accent to-tech-cyan rounded-2xl flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        Ready to Rescue Your Tech?
      </h2>
      
      <p class="text-xl text-gray-400 mb-12 max-w-2xl mx-auto">
        Don't let tech problems hold you back. Get expert help today—whether it's a smart home disaster, network issues, or just a consultation on what you need.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a href="tel:2165432060" class="group flex items-center justify-center space-x-3 bg-gradient-to-r from-tech-accent to-tech-cyan text-white px-8 py-4 rounded-full font-semibold text-lg hover:shadow-xl hover:shadow-tech-accent/25 transition-all">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span>Call (216) 543-2060</span>
        </a>
        
        <button class="flex items-center justify-center space-x-3 border-2 border-white/20 px-8 py-4 rounded-full font-semibold text-lg hover:bg-white/5 transition-all">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <span>Schedule Online</span>
        </button>
      </div>
      
      <div class="flex flex-wrap justify-center gap-8 text-gray-400">
        <div class="flex items-center space-x-2">
          <svg class="w-5 h-5 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span>ksavage5280@gmail.com</span>
        </div>
        
        <div class="flex items-center space-x-2">
          <svg class="w-5 h-5 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>Denver, CO</span>
        </div>
        
        <div class="flex items-center space-x-2">
          <svg class="w-5 h-5 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span>Mon-Fri 9am-7pm, Sat 10am-5pm</span>
        </div>
      </div>
    </div>
  </div>
</section>
