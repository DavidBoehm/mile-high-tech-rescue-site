---
---

<section id="how-it-works" class="py-24 bg-tech-darker">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        How We <span class="text-tech-accent">Rescue</span> Your Tech
      </h2>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Four simple steps from problem to solution. No jargon, no surprises.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Step 1 -->
      <div class="relative">
        <div class="bg-tech-card border border-white/10 rounded-2xl p-8 h-full">
          <div class="absolute -top-4 -right-4 w-12 h-12 bg-gradient-to-br from-tech-accent to-tech-cyan rounded-full flex items-center justify-center font-bold text-xl">
            1
          </div>
          
          <div class="w-16 h-16 bg-tech-accent/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          
          <h3 class="text-xl font-bold mb-3">Tell Us the Problem</h3>
          <p class="text-gray-400">
            Call, text, or book online. Describe what's broken or what you want to build. We'll ask the right questions.
          </p>
        </div>
        
        <!-- Connector -->
        <div class="hidden lg:block absolute top-1/2 -right-4 w-8 text-gray-600">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative">
        <div class="bg-tech-card border border-white/10 rounded-2xl p-8 h-full">
          <div class="absolute -top-4 -right-4 w-12 h-12 bg-gradient-to-br from-tech-accent to-tech-cyan rounded-full flex items-center justify-center font-bold text-xl">
            2
          </div>
          
          <div class="w-16 h-16 bg-tech-accent/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
            </svg>
          </div>
          
          <h3 class="text-xl font-bold mb-3">Get a Clear Quote</h3>
          <p class="text-gray-400">
            We diagnose remotely when possible, or schedule a visit. You'll get upfront pricing—no hidden fees or surprises.
          </p>
        </div>
        
        <div class="hidden lg:block absolute top-1/2 -right-4 w-8 text-gray-600">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="relative">
        <div class="bg-tech-card border border-white/10 rounded-2xl p-8 h-full">
          <div class="absolute -top-4 -right-4 w-12 h-12 bg-gradient-to-br from-tech-accent to-tech-cyan rounded-full flex items-center justify-center font-bold text-xl">
            3
          </div>
          
          <div class="w-16 h-16 bg-tech-accent/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          
          <h3 class="text-xl font-bold mb-3">We Fix It Fast</h3>
          <p class="text-gray-400">
            Our technicians arrive prepared. Most jobs completed same-day. We clean up after ourselves and show you how everything works.
          </p>
        </div>
        
        <div class="hidden lg:block absolute top-1/2 -right-4 w-8 text-gray-600">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </div>

      <!-- Step 4 -->
      <div class="relative">
        <div class="bg-tech-card border border-white/10 rounded-2xl p-8 h-full">
          <div class="absolute -top-4 -right-4 w-12 h-12 bg-gradient-to-br from-tech-accent to-tech-cyan rounded-full flex items-center justify-center font-bold text-xl">
            4
          </div>
          
          <div class="w-16 h-16 bg-tech-accent/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          
          <h3 class="text-xl font-bold mb-3">Stay Protected</h3>
          <p class="text-gray-400">
            All work guaranteed. We provide documentation, training, and ongoing support. Sleep easy knowing we've got your back.
          </p>
        </div>
      </div>
    </div>

    <!-- Trust badges -->
    <div class="mt-16 flex flex-wrap justify-center gap-8">
      <div class="flex items-center space-x-2 text-gray-400">
        <svg class="w-5 h-5 text-tech-accent" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span>90-Day Warranty</span>
      </div>
      
      <div class="flex items-center space-x-2 text-gray-400">
        <svg class="w-5 h-5 text-tech-accent" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span>Licensed & Bonded</span>
      </div>
      
      <div class="flex items-center space-x-2 text-gray-400">
        <svg class="w-5 h-5 text-tech-accent" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span>24/7 Emergency Support</span>
      </div>
    </div>
  </div>
</section>
