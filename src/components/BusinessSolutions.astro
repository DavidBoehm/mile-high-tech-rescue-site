---
---

<section id="business" class="py-24 bg-tech-darker relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 bg-gradient-to-br from-green-500/5 via-transparent to-blue-500/5"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center space-x-2 bg-green-500/20 border border-green-500/30 rounded-full px-4 py-2 mb-6">
        <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
        </svg>
        <span class="text-green-400 font-medium">Business Solutions</span>
      </div>
      
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        Technology That Pays for Itself Through <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-blue-400">Real Savings</span>
      </h2>
      
      <p class="text-xl text-gray-400">
        Smart investments in your business technology should deliver measurable returns. We focus on solutions that save you money, time, and headaches.
      </p>
    </div>
    
    <!-- Savings Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      
      <!-- Energy Savings -->
      <div class="bg-tech-card border border-white/10 rounded-2xl p-8 hover:border-green-500/50 transition-all group">
        <div class="w-16 h-16 bg-green-500/20 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        
        <h3 class="text-2xl font-bold mb-3 text-green-400">Energy Savings</h3>
        
        <p class="text-gray-400 mb-6">
          Smart thermostats, automated lighting, and power management that cut your utility bills month after month.
        </p>
        
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start space-x-3">
            <span class="text-green-400 font-bold">↓</span>
            <span>Smart thermostats learn your schedule</span>
          </li>
          <li class="flex items-start space-x-3">
            <span class="text-green-400 font-bold">↓</span>
            <span>Automated lighting reduces waste</span>
          </li>
          <li class="flex items-start space-x-3">
            <span class="text-green-400 font-bold">↓</span>
            <span>Energy usage tracking and insights</span>
          </li>
        </ul>
        
        <div class="mt-6 pt-6 border-t border-white/10">
          <p class="text-sm text-gray-500">Typical savings:</p>
          <p class="text-2xl font-bold text-green-400">10-30% on utilities</p>
        </div>
      </div>
      
      <!-- Time Savings -->
      <div class="bg-tech-card border border-white/10 rounded-2xl p-8 hover:border-blue-500/50 transition-all group">
        <div class="w-16 h-16 bg-blue-500/20 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        
        <h3 class="text-2xl font-bold mb-3 text-blue-400">Time Savings</h3>
        
        <p class="text-gray-400 mb-6">
          Automation that handles the repetitive stuff so your team can focus on what actually grows your business.
        </p>
        
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start space-x-3">
            <span class="text-blue-400 font-bold">⚡</span>
            <span>Automated scheduling and reminders</span>
          </li>
          <li class="flex items-start space-x-3">
            <span class="text-blue-400 font-bold">⚡</span>
            <span>One-touch meeting room setup</span>
          </li>
          <li class="flex items-start space-x-3">
            <span class="text-blue-400 font-bold">⚡</span>
            <span>Remote access and monitoring</span>
          </li>
        </ul>
        
        <div class="mt-6 pt-6 border-t border-white/10">
          <p class="text-sm text-gray-500">Reclaimed weekly:</p>
          <p class="text-2xl font-bold text-blue-400">5-10 hours</p>
        </div>
      </div>
      
      <!-- Security Savings -->
      <div class="bg-tech-card border border-white/10 rounded-2xl p-8 hover:border-purple-500/50 transition-all group">
        <div class="w-16 h-16 bg-purple-500/20 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        
        <h3 class="text-2xl font-bold mb-3 text-purple-400">Security Savings</h3>
        
        <p class="text-gray-400 mb-6">
          Protection against theft, data breaches, and downtime that could cost your business thousands.
        </p>
        
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start space-x-3">
            <span class="text-purple-400 font-bold">🛡️</span>
            <span>Smart access control and monitoring</span>
          </li>
          <li class="flex items-start space-x-3">
            <span class="text-purple-400 font-bold">🛡️</span>
            <span>Network security hardening</span>
          </li>
          <li class="flex items-start space-x-3">
            <span class="text-purple-400 font-bold">🛡️</span>
            <span>24/7 alerts and notifications</span>
          </li>
        </ul>
        
        <div class="mt-6 pt-6 border-t border-white/10">
          <p class="text-sm text-gray-500">Potential loss prevented:</p>
          <p class="text-2xl font-bold text-purple-400">$10K-$100K+</p>
        </div>
      </div>
    </div>
    
    <!-- ROI Calculator CTA -->
    <div class="bg-gradient-to-r from-tech-accent/10 to-tech-cyan/10 border border-tech-accent/20 rounded-3xl p-8 md:p-12">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <div>
          <h3 class="text-2xl md:text-3xl font-bold mb-3">See Your Potential ROI</h3>
          <p class="text-gray-400 max-w-xl">
            Every business is different. Let's look at your specific situation and calculate what smart technology could save you in year one.
          </p>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 flex-shrink-0">
          <a href="#contact" class="bg-tech-accent hover:bg-tech-cyan text-white px-8 py-4 rounded-full font-semibold text-lg transition-all hover:shadow-lg hover:shadow-tech-accent/25 text-center">
            Free Savings Assessment
          </a>
        </div>
      </div>
    </div>
    
  </div>
</section>
