---
---

<section class="py-16 bg-slate-900/50 border-y border-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-10">
      <p class="text-gray-400 text-sm uppercase tracking-widest">Trusted Platforms &amp; Brands</p>
    </div>
    
    <!-- Brand Icons Grid -->
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12 opacity-60 hover:opacity-100 transition-opacity duration-500">
      
      <!-- Google Home -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path class="text-blue-500" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">Google Home</span>
      </div>
      
      <!-- Amazon Alexa -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path class="text-cyan-400" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 0 0-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">Alexa</span>
      </div>
      
      <!-- Apple HomeKit -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8 text-gray-300" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 3L4 9v12h6v-7h4v7h6V9l-8-6zm0-2.27l9 6.75V21h-8v-7h-2v7H3V7.48l9-6.75z"/>
            <path d="M12 5.27l-6 4.5v9.23h4v-7h4v7h4V9.77l-6-4.5z" opacity="0.5"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">HomeKit</span>
      </div>
      
      <!-- Philips Hue -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path class="text-yellow-400" d="M9 3v1m0 16v1m9-9h-1M5 12H4m14.5-5.5l-.7.7M6.2 17.8l-.7.7m12 0l-.7-.7M6.2 6.2l-.7-.7M12 8a4 4 0 100 8 4 4 0 000-8z"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">Philips Hue</span>
      </div>
      
      <!-- Ring -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path class="text-cyan-300" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">Ring</span>
      </div>
      
      <!-- Nest -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path class="text-green-400" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">Nest</span>
      </div>
      
      <!-- SmartThings -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path class="text-indigo-400" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">SmartThings</span>
      </div>
      
      <!-- Sonos -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path class="text-white" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">Sonos</span>
      </div>
      
      <!-- UniFi -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path class="text-blue-400" d="M12 2L2 7v10l10 5 10-5V7L12 2zm0 2.18L19.82 8 12 11.82 4.18 8 12 4.18zM4 9.82l7 3.5v7l-7-3.5v-7zm9 10.5v-7l7-3.5v7l-7 3.5z"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">UniFi</span>
      </div>

      <!-- Home Assistant -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path class="text-blue-400" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            <path class="text-cyan-400" d="M12 7L7 9.5v5L12 17l5-2.5v-5L12 7z"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">Home Assistant</span>
      </div>

      <!-- ESP32 -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path class="text-green-500" d="M7 2v2h10V2H7zm0 4v12c0 1.1.9 2 2 2h6c1.1 0 2-.9 2-2V6H7zm2 2h6v2H9V8zm0 4h6v2H9v-2zm0 4h6v2H9v-2z"/>
            <path class="text-green-600" d="M4 6h2v12H4V6zm14 0h2v12h-2V6z"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">ESP32</span>
      </div>

      <!-- Matter -->
      <div class="group flex flex-col items-center gap-2">
        <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-800 group-hover:bg-slate-700 transition-colors duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path class="text-orange-400" d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path class="text-yellow-400" d="M2 17l10 5 10-5"/>
            <path class="text-green-400" d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">Matter</span>
      </div>
      
    </div>
    
  </div>
</section>
