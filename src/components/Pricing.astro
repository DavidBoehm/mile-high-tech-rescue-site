---
---

<section id="pricing" class="py-24 bg-tech-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Simple, <span class="text-tech-accent">Transparent</span> Pricing
      </h2>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        No hidden fees, no surprises. Choose the service that fits your needs.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <!-- Diagnostic -->
      <div class="bg-tech-card border border-white/10 rounded-2xl p-8 hover:border-white/20 transition-all">
        <h3 class="text-2xl font-bold mb-2">Tech Diagnostic</h3>
        <p class="text-gray-400 mb-6">For troubleshooting and assessment</p>
        
        <div class="flex items-baseline mb-8">
          <span class="text-5xl font-bold text-white">$99</span>
          <span class="text-gray-400 ml-2">flat fee</span>
        </div>
        
        <ul class="space-y-4 mb-8">
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            60-minute assessment
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Written diagnosis report
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Repair estimate included
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Applied to repairs if chosen
          </li>
        </ul>
        
        <button class="w-full py-4 border-2 border-white/20 rounded-full font-semibold hover:bg-white/5 transition-all">
          Book Diagnostic
        </button>
      </div>

      <!-- Standard Service -->
      <div class="bg-tech-card border-2 border-tech-accent rounded-2xl p-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 bg-tech-accent text-white px-4 py-1 text-sm font-semibold rounded-bl-xl">
          POPULAR
        </div>
        
        <h3 class="text-2xl font-bold mb-2">Standard Service</h3>
        <p class="text-gray-400 mb-6">For most home tech issues</p>
        
        <div class="flex items-baseline mb-8">
          <span class="text-5xl font-bold text-white">$199</span>
          <span class="text-gray-400 ml-2">starting</span>
        </div>
        
        <ul class="space-y-4 mb-8">
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Up to 3 hours of work
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Smart device setup (up to 5)
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            WiFi optimization
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            90-day warranty
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Training session included
          </li>
        </ul>
        
        <button class="w-full py-4 bg-gradient-to-r from-tech-accent to-tech-cyan rounded-full font-semibold text-white hover:shadow-lg hover:shadow-tech-accent/25 transition-all">
          Book Standard Service
        </button>
      </div>

      <!-- Enterprise -->
      <div class="bg-tech-card border border-white/10 rounded-2xl p-8 hover:border-white/20 transition-all">
        <h3 class="text-2xl font-bold mb-2">Business & Enterprise</h3>
        <p class="text-gray-400 mb-6">For offices & complex installs</p>
        
        <div class="flex items-baseline mb-8">
          <span class="text-5xl font-bold text-white">Custom</span>
        </div>
        
        <ul class="space-y-4 mb-8">
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Custom IoT deployment
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Network infrastructure
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Security hardening
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Ongoing support plans
          </li>
          <li class="flex items-center text-gray-300">
            <svg class="w-5 h-5 text-tech-accent mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            SLA agreements available
          </li>
        </ul>
        
        <button class="w-full py-4 border-2 border-white/20 rounded-full font-semibold hover:bg-white/5 transition-all">
          Get Custom Quote
        </button>
      </div>
    </div>
    
    <p class="text-center text-gray-400 mt-12">
      All services include travel within 25 miles of Denver. Additional fees may apply for expedited service or after-hours calls.
    </p>
  </div>
</section>
