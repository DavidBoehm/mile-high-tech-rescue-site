---
import DigitalRain from './DigitalRain.astro';
---

<section class="relative min-h-[85vh] flex flex-col justify-start overflow-hidden pt-32" aria-label="Hero section">
  <!-- Layer 1: Background base -->
  <div class="absolute inset-0 bg-gradient-to-br from-tech-dark via-tech-darker to-tech-dark"></div>
  
  <!-- Layer 2: Digital Rain (behind circles, behind content) -->
  <DigitalRain />
  
  <!-- Layer 3: Floating glow circles (above rain, below content) -->
  <div class="absolute inset-0 z-10 pointer-events-none">
    <!-- Blue accent - floats top left -->
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] 
                bg-blue-500/30 rounded-full blur-3xl 
                animate-float-1 animate-pulse-slow"></div>
    
    <!-- Cyan - floats bottom right -->
    <div class="absolute bottom-1/4 right-1/4 w-[450px] h-[450px] 
                bg-cyan-400/25 rounded-full blur-3xl 
                animate-float-2 animate-pulse-slow"
         style="animation-delay: 0.5s;"></div>
    
    <!-- Purple - floats middle -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] 
                bg-purple-500/20 rounded-full blur-3xl 
                animate-float-3 animate-pulse-slow"
         style="animation-delay: 1s;"></div>
    
    <!-- Indigo accent -->
    <div class="absolute top-1/3 right-1/3 w-[300px] h-[300px] 
                bg-indigo-500/15 rounded-full blur-3xl 
                animate-float-1"
         style="animation-delay: 2s;"></div>
    
    <!-- Pink accent -->
    <div class="absolute bottom-1/3 left-1/3 w-[350px] h-[350px] 
                bg-pink-500/10 rounded-full blur-3xl 
                animate-float-2"
         style="animation-delay: 3s;"></div>
  </div>
  
  <!-- Layer 4: Content (above everything) -->
  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="text-center">
      <!-- Main Headline - Senior Friendly: Large, Clear -->
      <h1 class="text-4xl md:text-6xl font-bold tracking-normal mb-4">
        <span class="bg-gradient-to-r from-white via-tech-accent to-tech-cyan bg-clip-text text-transparent">
          Smart Home Help Made Simple
        </span>
      </h1>
      
      <!-- Subheadline - Senior Friendly: Clear, jargon-free -->
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-8 leading-relaxed">
        We set up your TVs, streaming, and smart devices. <strong class="text-white">No confusing tech talk.</strong> Just friendly help that works.
      </p>
      
      <!-- CTAs - Senior Friendly: Clear buttons with phone prominent -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
        <a href="tel:+12165432060" 
           class="group relative px-10 py-5 bg-gradient-to-r from-tech-accent to-tech-cyan rounded-xl font-bold text-xl text-white shadow-lg shadow-tech-accent/25 hover:shadow-xl hover:shadow-tech-accent/40 transition-all"
           aria-label="Call Mile High Tech Rescue">
          📞 Call (216) 543-2060
          <span class="inline-block ml-2 group-hover:translate-x-1 transition-transform">→</span>
        </a>
        
        <a href="#services" 
           class="px-10 py-5 border-2 border-white/30 rounded-xl font-semibold text-lg hover:bg-white/10 transition-all"
           aria-label="View our services">
          See How We Help
        </a>
      </div>
      
      <!-- Trust Indicators - Senior Friendly: Clear, large icons -->
      <div class="flex flex-wrap items-center justify-center gap-6 text-gray-400 mb-10">
        <div class="flex items-center space-x-2 bg-white/5 px-4 py-2 rounded-full">
          <svg class="w-6 h-6 text-tech-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-base">Locally Owned</span>
        </div>
        
        <div class="flex items-center space-x-2 bg-white/5 px-4 py-2 rounded-full">
          <svg class="w-6 h-6 text-tech-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-base">Licensed &amp; Insured</span>
        </div>
        
        <div class="flex items-center space-x-2 bg-white/5 px-4 py-2 rounded-full">
          <svg class="w-6 h-6 text-tech-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-base">Patient &amp; Friendly</span>
        </div>
      </div>
      
      <!-- Service Areas - Simplified -->
      <div class="mb-10">
        <p class="text-base text-gray-400">Helping folks in: <span class="text-white">Denver • Littleton • Highlands Ranch • Centennial</span></p>
      </div>
      
      <!-- Mini Services Section - Cable Cutting & Streaming Setup -->
      <div class="mt-6 border-t border-white/10 pt-8">
        <h2 class="text-2xl font-bold text-white mb-6">Popular Services</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
          <!-- Cable Cutting -->
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-all">
            <div class="text-4xl mb-4">📺</div>
            <h3 class="text-xl font-bold text-white mb-2">Cut the Cable</h3>
            <p class="text-gray-400 text-base mb-4">Switch from expensive cable to streaming. We set up Roku, Fire TV, or Apple TV and show you how to use it.</p>
            <ul class="text-left text-gray-400 text-sm space-y-1">
              <li>✓ Netflix, Hulu, YouTube TV setup</li>
              <li>✓ One remote that works everything</li>
              <li>✓ Save $100+ per month</li>
            </ul>
          </div>
          
          <!-- Streaming Setup -->
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-all">
            <div class="text-4xl mb-4">🎬</div>
            <h3 class="text-xl font-bold text-white mb-2">Streaming Made Easy</h3>
            <p class="text-gray-400 text-base mb-4">Watch what you want, when you want. We make sure your internet is fast enough and everything connects.</p>
            <ul class="text-left text-gray-400 text-sm space-y-1">
              <li>✓ Wi-Fi speed check &amp; fix</li>
              <li>✓ Find shows across all apps</li>
              <li>✓ Written instructions included</li>
            </ul>
          </div>
        </div>
        
        <div class="mt-6">
          <a href="/solutions" class="inline-flex items-center text-tech-cyan hover:text-white transition-colors text-lg">
            See All Services 
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
