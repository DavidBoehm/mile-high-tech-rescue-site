---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16" aria-label="Hero section">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-br from-tech-dark via-tech-darker to-tech-dark"></div>
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-tech-accent/20 rounded-full blur-3xl animate-pulse-slow"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-tech-cyan/20 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center">
      <!-- Badge -->
      <div class="inline-flex items-center space-x-2 bg-tech-card/50 border border-tech-accent/30 rounded-full px-4 py-2 mb-8">
        <span class="w-2 h-2 bg-tech-cyan rounded-full animate-pulse"></span>
        <span class="text-sm text-gray-300">Serving Denver Metro Area</span>
      </div>
      
      <!-- Main Headline - Optimized for SEO keywords -->
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6">
        <span class="bg-gradient-to-r from-white via-tech-accent to-tech-cyan bg-clip-text text-transparent">
          Denver's Smart Home &amp; IoT Experts
        </span>
      </h1>
      
      <!-- Subheadline with keywords -->
      <p class="text-xl md:text-2xl text-gray-400 max-w-3xl mx-auto mb-10 leading-relaxed">
        Professional <strong class="text-white">smart home installation</strong> and <strong class="text-white">IoT integration services</strong> in Denver, Littleton, and Highlands Ranch. We handle setup, security, and automation so you don't have to.
      </p>
      
      <!-- CTAs with tracking -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
        <a href="tel:+12165432060" 
           class="group relative px-8 py-4 bg-gradient-to-r from-tech-accent to-tech-cyan rounded-full font-semibold text-lg text-white shadow-lg shadow-tech-accent/25 hover:shadow-xl hover:shadow-tech-accent/40 transition-all"
           aria-label="Call Mile High Tech Rescue">
          Call (216) 543-2060
          <span class="inline-block ml-2 group-hover:translate-x-1 transition-transform" aria-hidden="true">→</span>
        </a>
        
        <a href="#services" 
           class="px-8 py-4 border border-white/20 rounded-full font-semibold text-lg hover:bg-white/5 transition-all"
           aria-label="View our smart home services">
          Explore Services
        </a>
      </div>
      
      <!-- Trust Indicators with Schema -->
      <div class="flex flex-wrap items-center justify-center gap-8 text-gray-500" role="list" aria-label="Trust indicators">
        <div class="flex items-center space-x-2" role="listitem">
          <svg class="w-5 h-5 text-tech-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span>Denver-Based Experts</span>
        </div>
        
        <div class="flex items-center space-x-2" role="listitem">
          <svg class="w-5 h-5 text-tech-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span>Licensed &amp; Insured</span>
        </div>
        
        <div class="flex items-center space-x-2" role="listitem">
          <svg class="w-5 h-5 text-tech-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span>100% Satisfaction Guaranteed</span>
        </div>
      </div>
      
      <!-- Service Areas for SEO -->
      <div class="mt-12 pt-8 border-t border-white/10">
        <p class="text-sm text-gray-500 mb-4">Serving:</p>
        <div class="flex flex-wrap justify-center gap-4 text-sm text-gray-400">
          <span>Denver</span>
          <span aria-hidden="true">•</span>
          <span>Littleton</span>
          <span aria-hidden="true">•</span>
          <span>Highlands Ranch</span>
          <span aria-hidden="true">•</span>
          <span>Centennial</span>
          <span aria-hidden="true">•</span>
          <span>Lone Tree</span>
          <span aria-hidden="true">•</span>
          <span>Castle Rock</span>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce" aria-hidden="true">
    <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
