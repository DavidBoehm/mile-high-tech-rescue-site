---
---

<section id="tech-stack" class="py-24 bg-tech-darker relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center space-x-2 bg-tech-accent/20 border border-tech-accent/30 rounded-full px-4 py-2 mb-6">
        <svg class="w-5 h-5 text-tech-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
        </svg>
        <span class="text-tech-accent font-medium">Compatible Technologies</span>
      </div>
      
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        We Work With <span class="text-transparent bg-clip-text bg-gradient-to-r from-tech-accent to-tech-cyan">Everything</span>
      </h2>
      
      <p class="text-xl text-gray-400">
        From Apple HomeKit to Zigbee, we integrate with all major smart home platforms. No brand lock-in, just solutions that work.
      </p>
    </div>
    
    <!-- Tech Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-6">
      
      <!-- Apple HomeKit -->
      <div class="group bg-tech-card border border-white/10 rounded-2xl p-6 hover:border-tech-accent/50 transition-all hover:scale-105">
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-4 flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-12 h-12" fill="currentColor">
              <path class="text-gray-300 group-hover:text-white transition-colors" d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-lg mb-1">HomeKit</h3>
          <p class="text-sm text-gray-500">Apple</p>
        </div>
      </div>
      
      <!-- Matter -->
      <div class="group bg-tech-card border border-white/10 rounded-2xl p-6 hover:border-tech-accent/50 transition-all hover:scale-105">
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-4 flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5">
              <path class="text-gray-300 group-hover:text-white transition-colors" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="font-semibold text-lg mb-1">Matter</h3>
          <p class="text-sm text-gray-500">Universal</p>
        </div>
      </div>
      
      <!-- Google Home -->
      <div class="group bg-tech-card border border-white/10 rounded-2xl p-6 hover:border-tech-accent/50 transition-all hover:scale-105">
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-4 flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-12 h-12" fill="currentColor">
              <path class="text-gray-300 group-hover:text-white transition-colors" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-lg mb-1">Google Home</h3>
          <p class="text-sm text-gray-500">Google</p>
        </div>
      </div>
      
      <!-- Alexa -->
      <div class="group bg-tech-card border border-white/10 rounded-2xl p-6 hover:border-tech-accent/50 transition-all hover:scale-105">
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-4 flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-12 h-12" fill="currentColor">
              <path class="text-gray-300 group-hover:text-white transition-colors" d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.5 14h-9c-.28 0-.5-.22-.5-.5v-1c0-.28.22-.5.5-.5h9c.28 0 .5.22.5.5v1c0 .28-.22.5-.5.5zm0-3h-9c-.28 0-.5-.22-.5-.5v-1c0-.28.22-.5.5-.5h9c.28 0 .5.22.5.5v1c0 .28-.22.5-.5.5zm0-3h-9c-.28 0-.5-.22-.5-.5v-1c0-.28.22-.5.5-.5h9c.28 0 .5.22.5.5v1c0 .28-.22.5-.5.5z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-lg mb-1">Alexa</h3>
          <p class="text-sm text-gray-500">Amazon</p>
        </div>
      </div>
      
      <!-- Zigbee -->
      <div class="group bg-tech-card border border-white/10 rounded-2xl p-6 hover:border-tech-accent/50 transition-all hover:scale-105">
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-4 flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5">
              <path class="text-gray-300 group-hover:text-white transition-colors" d="M12 2l-9 4.5v11L12 22l9-4.5v-11L12 2z"/>
              <path class="text-gray-300 group-hover:text-white transition-colors" d="M12 12L3 7.5M12 12l9-4.5M12 12v10"/>
            </svg>
          </div>
          <h3 class="font-semibold text-lg mb-1">Zigbee</h3>
          <p class="text-sm text-gray-500">Wireless</p>
        </div>
      </div>
      
      <!-- Z-Wave -->
      <div class="group bg-tech-card border border-white/10 rounded-2xl p-6 hover:border-tech-accent/50 transition-all hover:scale-105">
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-4 flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle class="text-gray-300 group-hover:text-white transition-colors" cx="12" cy="12" r="10"/>
              <path class="text-gray-300 group-hover:text-white transition-colors" d="M12 6v6l4 2"/>
            </svg>
          </div>
          <h3 class="font-semibold text-lg mb-1">Z-Wave</h3>
          <p class="text-sm text-gray-500">Mesh Network</p>
        </div>
      </div>
      
      <!-- Home Assistant -->
      <div class="group bg-tech-card border border-white/10 rounded-2xl p-6 hover:border-tech-accent/50 transition-all hover:scale-105">
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-4 flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-12 h-12" fill="currentColor">
              <path class="text-gray-300 group-hover:text-white transition-colors" d="M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-lg mb-1">Home Assistant</h3>
          <p class="text-sm text-gray-500">Open Source</p>
        </div>
      </div>
      
    </div>
    
    <!-- Additional Info -->
    <div class="mt-16 text-center">
      <p class="text-gray-400 mb-6">
        Plus: SmartThings, Hubitat, Thread, WiFi, Bluetooth, and more. If it connects, we integrate it.
      </p>
      <a href="#contact" class="inline-flex items-center space-x-2 text-tech-accent hover:text-tech-cyan transition-colors font-semibold">
        <span>Discuss Your Setup</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
    
  </div>
</section>
