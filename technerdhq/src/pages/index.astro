---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="antialiased">
		<Header />
		<main>
			<!-- Hero Section with Tailwind -->
			<section class="py-12 lg:py-16">
				<div class="max-w-3xl">
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-indigo-50 text-indigo-700 text-sm font-medium mb-6">
						<span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
						<span>Littleton, CO</span>
					</div>
					
					<h1 class="text-4xl lg:text-5xl font-extrabold leading-tight mb-4">
						Tech tips that <span class="bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">actually work</span>
					</h1>
					
					<p class="text-lg text-slate-600 max-w-xl mb-8">
						WiFi, smart home, troubleshooting—clear guides for your tech problems. Serving Colorado and beyond.
					</p>
					
					<div class="flex flex-wrap gap-3 mb-10">
						<a 
							href="/blog" 
							class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg transition-colors"
						>
							Browse Articles
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</a>
						<a 
							href="https://milehightechrescue.com/contact" 
							class="inline-flex items-center gap-2 px-5 py-2.5 bg-white hover:bg-slate-50 text-slate-700 font-semibold rounded-lg border border-slate-200 transition-colors"
						>
							Get Tech Help
						</a>
					</div>
					
					<!-- Stats -->
					<div class="flex gap-8 pt-6 border-t border-slate-200">
						<div>
							<div class="text-2xl font-bold text-indigo-600">29</div>
							<div class="text-sm text-slate-500">Articles</div>
						</div>
						<div>
							<div class="text-2xl font-bold text-indigo-600">4</div>
							<div class="text-sm text-slate-500">Categories</div>
						</div>
						<div>
							<div class="text-2xl font-bold text-indigo-600">📍</div>
							<div class="text-sm text-slate-500">Colorado</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Bento Grid -->
			<section class="grid grid-cols-1 lg:grid-cols-3 gap-4 pt-4">
				<!-- Featured Article - spans 2 columns -->
				<article class="lg:col-span-2 bg-slate-50 rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg hover:-translate-y-0.5 transition-all">
					<div class="grid md:grid-cols-[200px_1fr]">
						<div class="h-40 md:h-auto bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-5xl">
							📡
						</div>
						<div class="p-6 flex flex-col">
							<span class="inline-flex px-2.5 py-0.5 rounded-full bg-amber-100 text-amber-700 text-xs font-semibold w-fit mb-3">Popular</span>
							<h2 class="text-xl font-bold mb-2">Why Your WiFi Sucks Upstairs (And How to Fix It)</h2>
							<p class="text-slate-600 text-sm mb-4 flex-1">Dead zones upstairs? Here's why it happens and the solutions that actually work—from mesh systems to strategic router placement.</p>
							<a href="/blog/why-your-wifi-sucks-upstairs" class="text-indigo-600 font-semibold hover:text-indigo-700">Read more →</a>
						</div>
					</div>
				</article>

				<!-- Quick Categories -->
				<article class="bg-slate-50 rounded-xl border border-slate-200 p-5 hover:shadow-lg hover:-translate-y-0.5 transition-all">
					<h3 class="text-base font-semibold mb-4">Browse by Topic</h3>
					<div class="flex flex-col gap-2">
						<a href="/blog?category=wifi" class="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors border-l-4 border-l-amber-500">
							<span>📶</span>
							<span class="font-medium text-sm">WiFi & Networking</span>
							<span class="ml-auto text-indigo-600 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all">→</span>
						</a>
						<a href="/blog?category=smart-home" class="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors border-l-4 border-l-emerald-500">
							<span>🏠</span>
							<span class="font-medium text-sm">Smart Home</span>
						</a>
						<a href="/blog?category=streaming" class="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors border-l-4 border-l-indigo-500">
							<span>📺</span>
							<span class="font-medium text-sm">Internet & Streaming</span>
						</a>
						<a href="/blog?category=troubleshooting" class="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors border-l-4 border-l-red-500">
							<span>🔧</span>
							<span class="font-medium text-sm">Troubleshooting</span>
						</a>
					</div>
				</article>

				<!-- Newsletter -->
				<article class="bg-gradient-to-br from-indigo-600 to-violet-700 rounded-xl p-6 text-white">
					<h3 class="text-lg font-semibold mb-2">Tech Tips in Your Inbox</h3>
					<p class="text-white/80 text-sm mb-4">Weekly guides for Colorado homeowners. No spam, unsubscribe anytime.</p>
					<form action="/api/subscribe" method="POST" class="flex flex-col sm:flex-row gap-2">
						<input 
							type="email" 
							name="email" 
							placeholder="your@email.com" 
							required 
							class="flex-1 px-4 py-2.5 rounded-lg bg-white/15 border-0 text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/30"
						/>
						<button 
							type="submit" 
							class="px-5 py-2.5 bg-white text-indigo-700 font-semibold rounded-lg hover:bg-white/90 transition-colors whitespace-nowrap"
						>
							Subscribe
						</button>
					</form>
				</article>

				<!-- Latest Posts - spans 2 columns -->
				<article class="lg:col-span-2 bg-slate-50 rounded-xl border border-slate-200 p-5 hover:shadow-lg hover:-translate-y-0.5 transition-all">
					<h3 class="text-base font-semibold mb-4">Latest Posts</h3>
					<ul class="space-y-3">
						<li>
							<a href="/blog/starlink-vs-xfinity-colorado" class="flex items-center justify-between gap-4 p-3 bg-white rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors">
								<span class="font-medium text-sm">Starlink vs Xfinity in Colorado</span>
								<span class="text-slate-400 text-xs whitespace-nowrap">Apr 22</span>
							</a>
						</li>
						<li>
							<a href="/blog/fix-printer-wifi-connection" class="flex items-center justify-between gap-4 p-3 bg-white rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors">
								<span class="font-medium text-sm">How to Fix a Printer That Won't Connect</span>
								<span class="text-slate-400 text-xs whitespace-nowrap">Apr 21</span>
							</a>
						</li>
						<li>
							<a href="/blog/windows-11-24h2-update-problems" class="flex items-center justify-between gap-4 p-3 bg-white rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors">
								<span class="font-medium text-sm">Windows 11 24H2 Update Problems & Fixes</span>
								<span class="text-slate-400 text-xs whitespace-nowrap">Apr 20</span>
							</a>
						</li>
					</ul>
					<a href="/blog" class="block text-center text-indigo-600 font-semibold mt-4 hover:text-indigo-700">View all posts →</a>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>
