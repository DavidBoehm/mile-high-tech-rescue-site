---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="hero">
				<div class="hero-content">
					<h1>Tech tips that actually work</h1>
					<p class="hero-subtitle">WiFi, smart home, troubleshooting—clear guides for your tech problems. Serving Littleton, Colorado and beyond.</p>
					<div class="hero-actions">
						<a href="/blog" class="btn btn-primary">Browse Articles</a>
						<a href="https://milehightechrescue.com/contact" class="btn btn-secondary">Get Tech Help</a>
					</div>
				</div>
				<div class="hero-visual">
					<div class="hero-card">
						<div class="card-icon">📶</div>
						<div class="card-text">
							<div class="card-label">WiFi Signal</div>
							<div class="card-value">Strong</div>
						</div>
					</div>
					<div class="hero-card">
						<div class="card-icon">🏠</div>
						<div class="card-text">
							<div class="card-label">Smart Home</div>
							<div class="card-value">Connected</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Bento Grid -->
			<section class="bento-grid">
				<!-- Featured Article -->
				<article class="bento-card featured">
					<div class="card-image" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
						<span class="image-icon">📡</span>
					</div>
					<div class="card-content">
						<span class="card-badge">Popular</span>
						<h2>Why Your WiFi Sucks Upstairs (And How to Fix It)</h2>
						<p>Dead zones upstairs? Here's why it happens and the solutions that actually work—from mesh systems to strategic router placement.</p>
						<a href="/blog/why-your-wifi-sucks-upstairs" class="card-link">Read more →</a>
					</div>
				</article>

				<!-- Quick Categories -->
				<article class="bento-card categories">
					<h3>Browse by Topic</h3>
					<div class="category-list">
						<a href="/blog?category=wifi" class="category-chip">
							<span class="chip-icon">📶</span>
							<span class="chip-label">WiFi & Networking</span>
						</a>
						<a href="/blog?category=smart-home" class="category-chip">
							<span class="chip-icon">🏠</span>
							<span class="chip-label">Smart Home</span>
						</a>
						<a href="/blog?category=streaming" class="category-chip">
							<span class="chip-icon">📺</span>
							<span class="chip-label">Internet & Streaming</span>
						</a>
						<a href="/blog?category=troubleshooting" class="category-chip">
							<span class="chip-icon">🔧</span>
							<span class="chip-label">Troubleshooting</span>
						</a>
					</div>
				</article>

				<!-- Newsletter -->
				<article class="bento-card newsletter">
					<div class="newsletter-content">
						<h3>Tech Tips in Your Inbox</h3>
						<p>Weekly guides for Colorado homeowners. No spam, unsubscribe anytime.</p>
						<form class="newsletter-form" action="/api/subscribe" method="POST">
							<input type="email" name="email" placeholder="your@email.com" required />
							<button type="submit" class="btn btn-primary">Subscribe</button>
						</form>
					</div>
				</article>

				<!-- Latest Posts -->
				<article class="bento-card latest-posts">
					<h3>Latest Posts</h3>
					<ul class="post-list">
						<li>
							<a href="/blog/starlink-vs-xfinity-colorado">
								<span class="post-title">Starlink vs Xfinity in Colorado</span>
								<span class="post-date">Apr 22, 2026</span>
							</a>
						</li>
						<li>
							<a href="/blog/fix-printer-wifi-connection">
								<span class="post-title">How to Fix a Printer That Won't Connect</span>
								<span class="post-date">Apr 21, 2026</span>
							</a>
						</li>
						<li>
							<a href="/blog/windows-11-24h2-update-problems">
								<span class="post-title">Windows 11 24H2 Update Problems & Fixes</span>
								<span class="post-date">Apr 20, 2026</span>
							</a>
						</li>
					</ul>
					<a href="/blog" class="view-all">View all posts →</a>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Hero Section */
	.hero {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 3rem;
		align-items: center;
		padding: 4rem 0;
		min-height: 60vh;
	}

	.hero-content h1 {
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 800;
		line-height: 1.1;
		margin: 0 0 1.5rem 0;
		background: linear-gradient(135deg, rgb(var(--text-primary)) 0%, rgb(var(--accent)) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-subtitle {
		font-size: 1.25rem;
		color: rgb(var(--text-secondary));
		margin: 0 0 2rem 0;
		max-width: 480px;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.875rem 1.5rem;
		border-radius: var(--radius);
		font-weight: 600;
		font-size: 0.95rem;
		text-decoration: none;
		transition: all 0.2s ease;
		cursor: pointer;
		border: none;
	}

	.btn-primary {
		background: rgb(var(--accent));
		color: white;
		box-shadow: var(--shadow);
	}

	.btn-primary:hover {
		background: rgb(var(--accent-dark));
		transform: translateY(-1px);
		box-shadow: var(--shadow-md);
	}

	.btn-secondary {
		background: rgb(var(--surface-elevated));
		color: rgb(var(--text-primary));
		border: 1px solid rgb(var(--border));
	}

	.btn-secondary:hover {
		background: rgb(var(--gray-light));
		transform: translateY(-1px);
	}

	/* Hero Visual Cards */
	.hero-visual {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		perspective: 1000px;
	}

	.hero-card {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: rgb(var(--surface-elevated));
		padding: 1.25rem 1.5rem;
		border-radius: var(--radius);
		border: 1px solid rgb(var(--border));
		box-shadow: var(--shadow);
		transition: all 0.3s ease;
	}

	.hero-card:nth-child(2) {
		transform: translateX(20px);
	}

	.hero-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}

	.card-icon {
		font-size: 1.5rem;
		width: 40px;
		text-align: center;
	}

	.card-label {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--text-secondary));
	}

	.card-value {
		font-weight: 700;
		color: rgb(var(--text-primary));
	}

	/* Bento Grid */
	.bento-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		padding: 2rem 0;
	}

	.bento-card {
		background: rgb(var(--surface-elevated));
		border-radius: var(--radius);
		border: 1px solid rgb(var(--border));
		overflow: hidden;
		transition: all 0.3s ease;
	}

	.bento-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	/* Featured Article - spans 2 columns */
	.bento-card.featured {
		grid-column: span 2;
		display: grid;
		grid-template-columns: 1fr 1fr;
	}

	.card-image {
		aspect-ratio: 4/3;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 4rem;
		position: relative;
	}

	.image-icon {
		opacity: 0.9;
	}

	.card-content {
		padding: 2rem;
		display: flex;
		flex-direction: column;
	}

	.card-badge {
		background: rgb(var(--accent));
		color: white;
		padding: 0.25rem 0.75rem;
		border-radius: 1rem;
		font-size: 0.75rem;
		font-weight: 600;
		width: fit-content;
		margin-bottom: 1rem;
	}

	.card-content h2 {
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0 0 1rem 0;
		line-height: 1.3;
	}

	.card-content p {
		color: rgb(var(--text-secondary));
		margin: 0 0 1.5rem 0;
		flex: 1;
	}

	.card-link {
		color: rgb(var(--accent));
		text-decoration: none;
		font-weight: 600;
		transition: color 0.2s;
	}

	.card-link:hover {
		color: rgb(var(--accent-dark));
	}

	/* Categories */
	.bento-card.categories {
		padding: 1.5rem;
	}

	.bento-card.categories h3 {
		font-size: 1.1rem;
		margin: 0 0 1rem 0;
		color: rgb(var(--text-primary));
	}

	.category-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.category-chip {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem 1rem;
		background: rgb(var(--surface));
		border-radius: var(--radius-sm);
		text-decoration: none;
		transition: all 0.2s;
		border: 1px solid rgb(var(--border));
	}

	.category-chip:hover {
		background: rgb(var(--gray-light));
		transform: translateX(4px);
	}

	.chip-icon {
		font-size: 1.25rem;
	}

	.chip-label {
		font-weight: 500;
		color: rgb(var(--text-primary));
		font-size: 0.9rem;
	}

	/* Newsletter */
	.bento-card.newsletter {
		padding: 2rem;
		background: linear-gradient(135deg, rgb(var(--accent)) 0%, rgb(var(--accent-dark)) 100%);
		color: white;
	}

	.newsletter-content h3 {
		font-size: 1.25rem;
		margin: 0 0 0.5rem 0;
	}

	.newsletter-content p {
		opacity: 0.9;
		margin: 0 0 1.5rem 0;
		font-size: 0.95rem;
	}

	.newsletter-form {
		display: flex;
		gap: 0.5rem;
	}

	.newsletter-form input {
		flex: 1;
		padding: 0.75rem 1rem;
		border: none;
		border-radius: var(--radius-sm);
		font-size: 0.9rem;
		background: rgba(255, 255, 255, 0.15);
		color: white;
		outline: none;
	}

	.newsletter-form input::placeholder {
		color: rgba(255, 255, 255, 0.7);
	}

	.newsletter-form button {
		padding: 0.75rem 1rem;
		background: white;
		color: rgb(var(--accent-dark));
		border: none;
		border-radius: var(--radius-sm);
		font-weight: 600;
		cursor: pointer;
		white-space: nowrap;
	}

	/* Latest Posts */
	.bento-card.latest-posts {
		padding: 1.5rem;
		grid-column: span 2;
	}

	.bento-card.latest-posts h3 {
		font-size: 1.1rem;
		margin: 0 0 1rem 0;
		color: rgb(var(--text-primary));
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.post-list li a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 1rem;
		background: rgb(var(--surface));
		border-radius: var(--radius-sm);
		text-decoration: none;
		border: 1px solid rgb(var(--border));
		transition: all 0.2s;
	}

	.post-list li a:hover {
		background: rgb(var(--gray-light));
		transform: translateX(4px);
	}

	.post-title {
		font-weight: 600;
		color: rgb(var(--text-primary));
	}

	.post-date {
		font-size: 0.85rem;
		color: rgb(var(--text-secondary));
		white-space: nowrap;
	}

	.view-all {
		display: block;
		margin-top: 1rem;
		text-align: center;
		color: rgb(var(--accent));
		text-decoration: none;
		font-weight: 600;
	}

	.view-all:hover {
		color: rgb(var(--accent-dark));
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.bento-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.bento-card.featured {
			grid-column: span 2;
		}
	}

	@media (max-width: 768px) {
		.hero {
			grid-template-columns: 1fr;
			padding: 2rem 0;
		}
		.hero-visual {
			display: none;
		}
		.bento-grid {
			grid-template-columns: 1fr;
		}
		.bento-card.featured,
		.bento-card.latest-posts {
			grid-column: span 1;
			grid-template-columns: 1fr;
		}
		.card-image {
			aspect-ratio: 16/9;
		}
		.newsletter-form {
			flex-direction: column;
		}
	}
</style>
